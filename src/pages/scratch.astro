---
import "../styles/guide.css";

/* ─────────────────────────────────────────────────────────────
   Scratch — TocPage terminal-shape comparisons.

   Four CLI paradigms applied to the same TOC data:

     1. tree (anchor)        — hierarchy via connectors
     2. ls -la               — tabular long-listing
     3. git log --oneline    — flat chronological scroll
     4. fzf                  — interactive picker

   Same data, four different shapes. Active page:
   "Writings" with three child writings.
   ───────────────────────────────────────────────────────────── */

type Kind = "cover" | "story" | "works" | "writings" | "writing" | "now" | "colophon" | "back";

type Entry = {
  toc: string;
  active?: boolean;
  kind: Kind;
  meta?: string;
  children?: Entry[];
};

const entries: Entry[] = [
  { toc: "Cover", kind: "cover" },
  { toc: "Story", kind: "story" },
  { toc: "Works", kind: "works" },
  {
    toc: "Writings",
    kind: "writings",
    active: true,
    children: [
      { toc: "We Fed Machines an Atlas…", kind: "writing", meta: "Apr 26" },
      { toc: "Ur — Manifesto", kind: "writing", meta: "Apr 21" },
      { toc: "Ur — Whitepaper", kind: "writing", meta: "Apr 18" },
    ],
  },
  { toc: "Now", kind: "now", meta: "Apr 2026" },
  { toc: "Colophon", kind: "colophon" },
  { toc: "Back-Cover", kind: "back" },
];

/* Flat chronological projection for git log + history shapes. */
const flat: { sha: string; date: string; subject: string; active?: boolean }[] = [
  { sha: "a1b2c3d", date: "2026-04-26", subject: "We Fed Machines an Atlas…" },
  { sha: "e4f5g6h", date: "2026-04-26", subject: "Writings · index", active: true },
  { sha: "9c0d1e2", date: "2026-04-21", subject: "Ur — Manifesto" },
  { sha: "7a8b9c0", date: "2026-04-18", subject: "Ur — Whitepaper" },
  { sha: "5d6e7f8", date: "2026-04-15", subject: "Now · Apr 2026" },
  { sha: "3a4b5c6", date: "2026-04-10", subject: "Works" },
  { sha: "1f2a3b4", date: "2026-04-08", subject: "Story" },
  { sha: "0d1e2f3", date: "2026-04-05", subject: "Colophon" },
  { sha: "f9e8d7c", date: "2026-04-01", subject: "Cover" },
];

/* Tabular projection for ls -la shape. Perms invented as state-codes:
     drwxr-xr-x → chapter dir
     -rw-r--r-- → published writing
     -rw-rw---- → draft (illustrative; nothing's drafty here) */
const lsRows: { perms: string; size: string; date: string; name: string; isDir: boolean; active?: boolean; child?: boolean }[] = [
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 24", name: "cover/", isDir: true },
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 24", name: "story/", isDir: true },
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 24", name: "works/", isDir: true },
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 26", name: "writings/", isDir: true, active: true },
  { perms: "-rw-r--r--", size: " 12k", date: "Apr 26", name: "atlas.md", isDir: false, child: true },
  { perms: "-rw-r--r--", size: "  9k", date: "Apr 21", name: "ur-manifesto.md", isDir: false, child: true },
  { perms: "-rw-r--r--", size: " 14k", date: "Apr 18", name: "ur-whitepaper.md", isDir: false, child: true },
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 26", name: "now/", isDir: true },
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 24", name: "colophon/", isDir: true },
  { perms: "drwxr-xr-x", size: "  4k", date: "Apr 24", name: "back/", isDir: true },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Scratch · TocPage terminal-shape comparisons</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <header class="study-head">
    <h1>TocPage · terminal-shape comparisons</h1>
    <p class="sub">same data, four CLI paradigms. active page: <em>Writings</em> with three child writings.</p>
  </header>

  <div class="study-grid">
    {/* ───────── 1 · tree (anchor) ───────── */}
    <article class="study">
      <header class="study-card-head">
        <h2><span class="num">1</span> tree <span class="badge">anchor</span></h2>
        <p>hierarchy via vine connectors · grimoire glyphs · candle-flame cursor on the active leaf.</p>
      </header>
      <div class="page">
        <div class="prompt-line">
          <span class="prompt-glyph">❦</span><span class="path">/dyllan.to</span>
          <span class="cmd"> ❯ tree</span>
        </div>
        <div class="tree">
          <div class="tree-root">❧</div>
          {entries.map((entry, i) => {
            const last = i === entries.length - 1;
            const hasNested = entry.active && entry.children && entry.children.length > 0;
            const closesBranch = last && !hasNested;
            return (
              <>
                <div class:list={["row", { active: entry.active }]}>
                  <span class="branch">{closesBranch ? "╰─" : "├─"}</span>
                  <span class:list={["leaf", { "leaf-active": entry.active }]}>{entry.toc}</span>
                  {entry.active && <span class="cursor">✦</span>}
                  {entry.meta && <span class="meta">{entry.meta}</span>}
                </div>
                {hasNested && entry.children!.map((child, ci) => {
                  const lastChild = ci === entry.children!.length - 1;
                  return (
                    <div class="row child-row">
                      <span class="branch child-branch">{last ? "   " : "╎  "}{lastChild ? "╰─" : "├─"}</span>
                      <span class="leaf child-leaf">{child.toc}</span>
                      {child.meta && <span class="meta">{child.meta}</span>}
                    </div>
                  );
                })}
              </>
            );
          })}
        </div>
        <div class="scanlines"></div>
      </div>
    </article>

    {/* ───────── 2 · ls -la ───────── */}
    <article class="study">
      <header class="study-card-head">
        <h2><span class="num">2</span> ls -la</h2>
        <p>tabular long-listing · perms as state-code · size / date / name columns · grounded, utilitarian.</p>
      </header>
      <div class="page page-ls">
        <div class="prompt-line">
          <span class="prompt-glyph">❦</span><span class="path">/dyllan.to</span>
          <span class="cmd"> ❯ ls -la</span>
        </div>
        <div class="ls-total">total {lsRows.length}</div>
        <div class="ls-grid">
          {lsRows.map((r) => (
            <div class:list={["ls-row", { active: r.active, child: r.child }]}>
              <span class="ls-perms">{r.perms}</span>
              <span class="ls-size">{r.size}</span>
              <span class="ls-date">{r.date}</span>
              <span class:list={["ls-name", { dir: r.isDir, "name-active": r.active }]}>{r.name}</span>
              {r.active && <span class="cursor cursor-inline">✦</span>}
            </div>
          ))}
        </div>
        <div class="scanlines"></div>
      </div>
    </article>

    {/* ───────── 3 · git log --oneline ───────── */}
    <article class="study">
      <header class="study-card-head">
        <h2><span class="num">3</span> git log --oneline</h2>
        <p>flat reverse-chron scroll · sha rune + subject · each chapter a commit to the canon.</p>
      </header>
      <div class="page page-log">
        <div class="prompt-line">
          <span class="prompt-glyph">❦</span><span class="path">/dyllan.to</span>
          <span class="cmd"> ❯ git log --oneline</span>
        </div>
        <div class="log-grid">
          {flat.map((c) => (
            <div class:list={["log-row", { active: c.active }]}>
              {c.active
                ? <span class="log-head">HEAD →</span>
                : <span class="log-head log-head-spacer">      </span>}
              <span class="log-sha">{c.sha}</span>
              <span class:list={["log-subject", { "log-subject-active": c.active }]}>{c.subject}</span>
              {c.active && <span class="cursor cursor-inline">✦</span>}
            </div>
          ))}
        </div>
        <div class="scanlines"></div>
      </div>
    </article>

    {/* ───────── 4 · fzf picker ───────── */}
    <article class="study">
      <header class="study-card-head">
        <h2><span class="num">4</span> fzf</h2>
        <p>interactive picker · query at top · ranked list · selected row pointed at by <code>{`>`}</code> · count footer.</p>
      </header>
      <div class="page page-fzf">
        <div class="prompt-line">
          <span class="prompt-glyph">❦</span><span class="path">/dyllan.to</span>
          <span class="cmd"> ❯ fzf</span>
        </div>
        <div class="fzf-results">
          {entries.map((entry) => (
            <>
              <div class:list={["fzf-row", { active: entry.active }]}>
                <span class="fzf-pointer">{entry.active ? ">" : " "}</span>
                <span class:list={["leaf", { "leaf-active": entry.active }]}>{entry.toc}</span>
                {entry.meta && <span class="meta">{entry.meta}</span>}
              </div>
              {entry.active && entry.children!.map((child) => (
                <div class="fzf-row fzf-child">
                  <span class="fzf-pointer"> </span>
                  <span class="fzf-arrow">↳</span>
                  <span class="leaf child-leaf">{child.toc}</span>
                  {child.meta && <span class="meta">{child.meta}</span>}
                </div>
              ))}
            </>
          ))}
        </div>
        <div class="fzf-footer">
          <span class="fzf-count">{entries.length + 3}/{entries.length + 3}</span>
          <span class="fzf-rule">─────────────────</span>
        </div>
        <div class="fzf-query">
          <span class="fzf-prompt">{`>`}</span>
          <span class="fzf-input">writ</span>
          <span class="cursor cursor-inline">✦</span>
        </div>
        <div class="scanlines"></div>
      </div>
    </article>
  </div>
</body>
</html>

<style>
  body {
    margin: 0;
    background: #1a1410;
    color: var(--tome-paper);
    font-family: var(--tome-font-body);
    min-height: 100vh;
    padding: 32px 28px 48px;
    box-sizing: border-box;
  }

  .study-head {
    max-width: 1280px;
    margin: 0 auto 28px;
    color: var(--tome-paper);
  }
  .study-head h1 {
    font-family: var(--tome-font-display);
    font-weight: 500;
    font-size: 1.4rem;
    margin: 0 0 4px;
    letter-spacing: 0.04em;
  }
  .study-head .sub {
    font-family: var(--tome-font-mono);
    font-size: 0.8rem;
    color: rgba(240, 228, 204, 0.6);
    margin: 0;
    letter-spacing: 0.02em;
  }
  .study-head em {
    color: var(--tome-term-green);
    font-style: normal;
  }

  .study-grid {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .study {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .study-card-head h2 {
    font-family: var(--tome-font-heading);
    font-weight: 500;
    font-size: 1rem;
    margin: 0 0 4px;
    color: var(--tome-paper);
    letter-spacing: 0.04em;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .study-card-head .num {
    font-family: var(--tome-font-mono);
    color: var(--tome-copper);
    font-size: 0.75rem;
    opacity: 0.7;
  }
  .badge {
    display: inline-block;
    padding: 1px 6px;
    font-family: var(--tome-font-mono);
    font-size: 0.6rem;
    background: var(--tome-term-green);
    color: var(--tome-paper);
    border-radius: 2px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    vertical-align: middle;
  }
  .study-card-head p {
    font-family: var(--tome-font-mono);
    font-size: 0.7rem;
    color: rgba(240, 228, 204, 0.55);
    margin: 0;
    line-height: 1.5;
    letter-spacing: 0.01em;
  }
  .study-card-head code {
    font-family: var(--tome-font-mono);
    font-size: 0.65rem;
    color: var(--tome-term-green);
    padding: 0 3px;
    background: rgba(45, 107, 63, 0.12);
    border-radius: 2px;
  }

  /* ─── Faux page ─────────────────────────────────────────── */
  .page {
    width: 100%;
    aspect-ratio: 4 / 5;
    box-sizing: border-box;
    padding: 36px 22px 18px;
    position: relative;
    overflow: hidden;
    background: var(--tome-bg-paper);
    border-radius: 2px;
    box-shadow:
      0 1px 0 rgba(0, 0, 0, 0.4),
      0 12px 28px rgba(0, 0, 0, 0.45);
    font-family: var(--tome-font-mono);
  }

  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.015) 2px,
      rgba(0, 0, 0, 0.015) 4px
    );
    pointer-events: none;
  }

  /* ─── Shared prompt line ─────────────────────────────────── */
  .prompt-line {
    margin-bottom: 14px;
    line-height: 1.4;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }
  .prompt-glyph {
    color: var(--tome-copper);
    margin-right: 2px;
    font-size: 0.95rem;
    vertical-align: -1px;
  }
  .path {
    color: var(--tome-term-green);
    opacity: 0.95;
  }
  .cmd {
    color: var(--tome-ink);
    opacity: 0.7;
  }

  /* ─── Shared row tokens ──────────────────────────────────── */
  .leaf {
    color: var(--tome-ink);
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    transition: color 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .leaf-active {
    color: var(--tome-term-green);
    text-shadow: 0 0 8px rgba(45, 107, 63, 0.3);
  }
  .child-leaf {
    color: var(--tome-ink-light);
    font-size: 0.82rem;
  }
  .meta {
    margin-left: auto;
    padding-left: 10px;
    font-family: var(--tome-font-mono);
    font-size: 0.65rem;
    color: var(--tome-term-dim);
    letter-spacing: 0.04em;
    opacity: 0.75;
    flex-shrink: 0;
  }
  .cursor {
    color: var(--tome-term-green);
    font-size: 0.95rem;
    margin-left: 6px;
    flex-shrink: 0;
    animation: flicker 1.6s ease-in-out infinite;
    text-shadow: 0 0 6px rgba(45, 107, 63, 0.5);
  }
  .cursor-inline {
    margin-left: 6px;
  }
  @keyframes flicker {
    0%, 100% { opacity: 0.95; transform: translateY(0); }
    35% { opacity: 0.6; transform: translateY(-0.5px); }
    65% { opacity: 1; transform: translateY(0.3px); }
  }

  /* ─── 1 · tree ───────────────────────────────────────────── */
  .tree {
    display: flex;
    flex-direction: column;
    color: var(--tome-ink);
  }
  .tree-root {
    color: var(--tome-copper);
    opacity: 0.6;
    font-size: 1rem;
    padding: 0 0 2px 2px;
    line-height: 1.5;
  }
  .row {
    display: flex;
    align-items: center;
    padding: 2px 8px;
    margin: 0 -8px;
    line-height: 1.5;
    border-radius: 2px;
    position: relative;
    transition: background 0.18s;
  }
  .row:hover {
    background: rgba(45, 107, 63, 0.06);
  }
  .row:hover .leaf {
    color: var(--tome-term-green);
  }
  .row.active {
    background: rgba(45, 107, 63, 0.1);
    box-shadow: inset 2px 0 0 var(--tome-term-green);
  }
  .branch {
    color: var(--tome-copper);
    opacity: 0.6;
    font-size: 0.85rem;
    white-space: pre;
    flex-shrink: 0;
    margin-right: 8px;
    user-select: none;
  }
  .child-branch {
    opacity: 0.5;
  }

  /* ─── 2 · ls -la ─────────────────────────────────────────── */
  .ls-total {
    color: var(--tome-term-dim);
    font-size: 0.72rem;
    opacity: 0.65;
    margin-bottom: 4px;
    letter-spacing: 0.02em;
  }
  .ls-grid {
    display: flex;
    flex-direction: column;
  }
  .ls-row {
    display: grid;
    grid-template-columns: auto auto auto 1fr auto;
    gap: 10px;
    align-items: baseline;
    padding: 1px 8px;
    margin: 0 -8px;
    line-height: 1.45;
    border-radius: 2px;
    position: relative;
    transition: background 0.18s;
  }
  .ls-row:hover {
    background: rgba(45, 107, 63, 0.06);
  }
  .ls-row.active {
    background: rgba(45, 107, 63, 0.1);
    box-shadow: inset 2px 0 0 var(--tome-term-green);
  }
  .ls-row.child {
    padding-left: 16px;
  }
  .ls-perms {
    font-size: 0.72rem;
    color: var(--tome-copper);
    opacity: 0.7;
    letter-spacing: 0.04em;
  }
  .ls-size {
    font-size: 0.7rem;
    color: var(--tome-term-dim);
    opacity: 0.7;
    text-align: right;
  }
  .ls-date {
    font-size: 0.7rem;
    color: var(--tome-term-dim);
    opacity: 0.75;
    letter-spacing: 0.03em;
  }
  .ls-name {
    font-size: 0.85rem;
    color: var(--tome-ink);
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ls-name.dir {
    color: var(--tome-term-green);
    opacity: 0.85;
  }
  .ls-row:hover .ls-name {
    color: var(--tome-term-green);
  }
  .ls-name.name-active {
    color: var(--tome-term-green);
    text-shadow: 0 0 8px rgba(45, 107, 63, 0.3);
    opacity: 1;
  }

  /* ─── 3 · git log ────────────────────────────────────────── */
  .log-grid {
    display: flex;
    flex-direction: column;
  }
  .log-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 1px 8px;
    margin: 0 -8px;
    line-height: 1.5;
    border-radius: 2px;
    position: relative;
    transition: background 0.18s;
  }
  .log-row:hover {
    background: rgba(45, 107, 63, 0.06);
  }
  .log-row:hover .log-subject {
    color: var(--tome-term-green);
  }
  .log-row.active {
    background: rgba(45, 107, 63, 0.1);
    box-shadow: inset 2px 0 0 var(--tome-term-green);
  }
  .log-head {
    font-size: 0.65rem;
    color: var(--tome-term-green);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    flex-shrink: 0;
    width: 4.2em;
  }
  .log-head-spacer {
    visibility: hidden;
  }
  .log-sha {
    font-size: 0.78rem;
    color: var(--tome-copper);
    opacity: 0.85;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  .log-subject {
    font-size: 0.85rem;
    color: var(--tome-ink);
    letter-spacing: 0.01em;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .log-subject-active {
    color: var(--tome-term-green);
    text-shadow: 0 0 8px rgba(45, 107, 63, 0.3);
  }

  /* ─── 4 · fzf ───────────────────────────────────────────── */
  .page-fzf {
    display: flex;
    flex-direction: column;
  }
  .fzf-results {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .fzf-row {
    display: flex;
    align-items: center;
    padding: 1px 8px;
    margin: 0 -8px;
    line-height: 1.5;
    border-radius: 2px;
    transition: background 0.18s;
  }
  .fzf-row:hover {
    background: rgba(45, 107, 63, 0.06);
  }
  .fzf-row:hover .leaf {
    color: var(--tome-term-green);
  }
  .fzf-row.active {
    background: rgba(45, 107, 63, 0.1);
    box-shadow: inset 2px 0 0 var(--tome-term-green);
  }
  .fzf-pointer {
    color: var(--tome-term-green);
    font-size: 0.85rem;
    width: 1.1em;
    flex-shrink: 0;
    font-weight: 600;
  }
  .fzf-arrow {
    color: var(--tome-term-dim);
    font-size: 0.78rem;
    margin-right: 4px;
  }
  .fzf-child {
    padding-left: 16px;
  }
  .fzf-footer {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 8px;
    padding-top: 4px;
  }
  .fzf-count {
    font-size: 0.7rem;
    color: var(--tome-term-green);
    opacity: 0.85;
    letter-spacing: 0.04em;
  }
  .fzf-rule {
    color: var(--tome-copper);
    opacity: 0.4;
    font-size: 0.7rem;
    flex: 1;
    overflow: hidden;
    white-space: nowrap;
  }
  .fzf-query {
    display: flex;
    align-items: center;
    margin-top: 2px;
    font-size: 0.85rem;
  }
  .fzf-prompt {
    color: var(--tome-term-green);
    margin-right: 6px;
    font-weight: 600;
  }
  .fzf-input {
    color: var(--tome-ink);
    letter-spacing: 0.04em;
  }

  /* ─── Stack on narrow ────────────────────────────────────── */
  @media (max-width: 980px) {
