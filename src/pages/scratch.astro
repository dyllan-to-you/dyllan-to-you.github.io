  <script is:inline>
    (() => {
      const GRADIENT = ["#B7410E", "#CF6C1C", "#E0932C", "#D4AF37", "#F0D96D", "#F5E99F"];
      const R_PHOTO = 70;
      const NUM_BUCKETS = 32;

      function F(N) {
        return Math.cos(Math.PI / N) + Math.sqrt(3) * Math.sin(Math.PI / N);
      }

      function buildSunRings(r0, N1, M, K, rMax) {
        const rings = [];
        let N = N1, rBase = r0, alpha = 0;
        for (let k = 0; k < K; k++) {
          const rApex = rBase * F(N);
          if (rApex > rMax) break;
          rings.push({ N, alpha, rBase, rApex });
          alpha += Math.PI / N;
          rBase = rApex;
          const nextN = N / M;
          if (!Number.isInteger(nextN) || nextN < 3) break;
          N = nextN;
        }
        return rings;
      }

      function triVerts(ring, j) {
        const step = (2 * Math.PI) / ring.N;
        const t1 = ring.alpha + j * step;
        const t2 = ring.alpha + (j + 1) * step;
        const ta = ring.alpha + (j + 0.5) * step;
        return [
          [ring.rBase * Math.cos(t1), ring.rBase * Math.sin(t1)],
          [ring.rBase * Math.cos(t2), ring.rBase * Math.sin(t2)],
          [ring.rApex * Math.cos(ta), ring.rApex * Math.sin(ta)],
        ];
      }

      function sierpinskiLeaves(A, B, C, minSize) {
        const out = [];
        const stack = [[A, B, C]];
        while (stack.length) {
          const [p, q, r] = stack.pop();
          const dx = p[0] - q[0], dy = p[1] - q[1];
          if (dx * dx + dy * dy <= minSize * minSize) {
            const cx = (p[0] + q[0] + r[0]) / 3;
            const cy = (p[1] + q[1] + r[1]) / 3;
            out.push({
              d: `M${p[0].toFixed(2)} ${p[1].toFixed(2)}L${q[0].toFixed(2)} ${q[1].toFixed(2)}L${r[0].toFixed(2)} ${r[1].toFixed(2)}Z`,
              r: Math.sqrt(cx*cx + cy*cy),
            });
            continue;
          }
          const mPQ = [(p[0]+q[0])/2, (p[1]+q[1])/2];
          const mPR = [(p[0]+r[0])/2, (p[1]+r[1])/2];
          const mQR = [(q[0]+r[0])/2, (q[1]+r[1])/2];
          stack.push([p, mPQ, mPR]);
          stack.push([mPQ, q, mQR]);
          stack.push([mPR, mQR, r]);
        }
        return out;
      }

      function gradientAt(t) {
        t = Math.max(0, Math.min(1, t));
        const idx = t * (GRADIENT.length - 1);
        const i = Math.min(Math.floor(idx), GRADIENT.length - 2);
        const f = idx - i;
        const hx = (s, n) => parseInt(s.slice(1 + n * 2, 3 + n * 2), 16);
        const to2 = (x) => Math.round(x).toString(16).padStart(2, "0");
        const r = hx(GRADIENT[i], 0) + f * (hx(GRADIENT[i+1], 0) - hx(GRADIENT[i], 0));
        const g = hx(GRADIENT[i], 1) + f * (hx(GRADIENT[i+1], 1) - hx(GRADIENT[i], 1));
        const b = hx(GRADIENT[i], 2) + f * (hx(GRADIENT[i+1], 2) - hx(GRADIENT[i], 2));
        return `#${to2(r)}${to2(g)}${to2(b)}`;
      }

      function render(rings, minSize, strokeWidth) {
        if (rings.length === 0) return "";
        const rFinal = rings[rings.length - 1].rApex;
        const range = Math.max(1e-6, rFinal - R_PHOTO);
        const ds = Array.from({length: NUM_BUCKETS}, () => "");
        for (const ring of rings) {
          for (let j = 0; j < ring.N; j++) {
            const [A, B, C] = triVerts(ring, j);
            const leaves = sierpinskiLeaves(A, B, C, minSize);
            for (const lf of leaves) {
              const t = (lf.r - R_PHOTO) / range;
              const bi = Math.max(0, Math.min(NUM_BUCKETS - 1, Math.floor(t * NUM_BUCKETS)));
              ds[bi] += lf.d;
            }
          }
        }
        const out = [];
        for (let i = 0; i < NUM_BUCKETS; i++) {
          if (!ds[i]) continue;
          const color = gradientAt(i / (NUM_BUCKETS - 1));
          out.push(`<path d="${ds[i]}" fill="${color}" stroke="${color}" stroke-width="${strokeWidth}" stroke-linejoin="miter" opacity="0.96"/>`);
        }
        return out.join("");
      }

      const root = document.getElementById('v5-root');
      const status = document.getElementById('v5-status');
      const read = () => ({
        N1: parseInt(document.getElementById('s-n1').value, 10),
        M:  parseInt(document.getElementById('s-m').value, 10),
        K:  parseInt(document.getElementById('s-k').value, 10),
        rMax: parseInt(document.getElementById('s-rmax').value, 10),
        minSize: parseFloat(document.getElementById('s-min').value),
        sw: parseFloat(document.getElementById('s-sw').value),
      });
      const update = () => {
        const p = read();
        document.getElementById('v-k').textContent = p.K;
        document.getElementById('v-rmax').textContent = p.rMax;
        document.getElementById('v-min').textContent = p.minSize.toFixed(2);
        document.getElementById('v-sw').textContent = p.sw.toFixed(2);
        const rings = buildSunRings(R_PHOTO, p.N1, p.M, p.K, p.rMax);
        root.innerHTML = render(rings, p.minSize, p.sw);
        const ringCounts = rings.map(r => r.N).join(" → ");
        const rFinal = rings.length ? rings[rings.length-1].rApex.toFixed(1) : "—";
        status.innerHTML = `rings built: <em>${rings.length}/${p.K}</em> · counts: <em>${ringCounts || "(none fit)"}</em> · r_final: <em>${rFinal}</em>`;
      };
      ['s-n1','s-m','s-k','s-rmax','s-min','s-sw'].forEach(id => {
        document.getElementById(id).addEventListener('input', update);
      });
      update();
    })();
  </script>


  <div class="notes-block">
    <p><b>The rule is an invariant, not a wish.</b></p>
    <p>Every ring's geometry — radii, triangle sizes, offsets — is <em>derived</em> from the single constraint that each next-ring base corner coincides with an apex of the previous ring. There are no free parameters beyond (r₀, N₁, M, K, r_max, minSize).</p>
    <p><b>Per-leaf gradient:</b> every Sierpiński leaf is colored by its own radial distance from the center, then packed into 32 radial buckets so adjacent rings blend rather than step. Each bucket becomes one concatenated <code>&lt;path&gt;</code> — 32 paths total per variant regardless of leaf count.</p>
    <p><b>Thin lines:</b> <code>stroke-width="0.08"</code> matching the fill color closes sub-pixel hairline cracks without painting over the intended Sierpiński negative space. The "lines" you see are the removed-middle triangles at each recursion level, not stroke.</p>
    <p><b>Key formulas:</b><br/>
    — side<sub>k</sub> = 2·r<sub>k</sub><sup>base</sup>·sin(π/N<sub>k</sub>)<br/>
    — r<sub>k</sub><sup>apex</sup> = r<sub>k</sub><sup>base</sup> · (cos(π/N<sub>k</sub>) + √3·sin(π/N<sub>k</sub>)) = r · F(N)<br/>
    — r<sub>k+1</sub><sup>base</sup> = r<sub>k</sub><sup>apex</sup> &nbsp;(next ring's base on previous apex circle)<br/>
    — α<sub>k+1</sub> = α<sub>k</sub> + π/N<sub>k</sub> &nbsp;(half-step offset so corners land on apexes, not chord midpoints)<br/>
    — N<sub>k+1</sub> = N<sub>k</sub> / M &nbsp;(M=1 or M=2)</p>
    <p><b>Growth factors F(N):</b></p>
    <p>F(8) = 1.587 · F(16) = 1.319 · F(24) = 1.212 · F(32) = 1.165 · F(48) = 1.108 · F(64) = 1.080 · F(96) = 1.053 · F(128) = 1.041 · F(256) = 1.020</p>
    <p><b>Radial budget per variant (r₀ = 70):</b><br/>
    — D (128→64→32→16, K=4): r_final ≈ 70·1.0422·1.0838·1.1650·1.3188 = <em>121.5</em> · fits within r_max = 132<br/>
    — E (128→64→32→16, crown N=16 sparse 8/16): r_final ≈ 121.5·1.3188 = <em>160.3</em> · crown keeps ring-4 triangle size</p>
    <p><b>Does chord-on-R construction always intrude on the prior layer?</b> Yes — at every transition, not just halving jumps. The chord between two points on a circle always dips inside the circle; the region above the chord but below the arc (the <em>sagitta sliver</em>) is simultaneously in ring-(k+1)'s body AND in ring-k territory.</p>
    <p><b>Sagitta depth per transition</b> (how far ring-(k+1)'s chord dips below r_k<sup>apex</sup>): equals r_k<sup>apex</sup> · (1 − cos(π/N_(k+1))).<br/>
    — any transition into N=128: <em>0.030%</em><br/>
    — into N=64: <em>0.12%</em><br/>
    — into N=32: <em>0.48%</em><br/>
    — into N=16: <em>1.9%</em><br/>
    — into N=8: <em>7.6%</em></p>
    <p>At the M=2 halving <em>corner angles</em>, skipped ring-k apexes poke through by even more because they sit at arc midpoints (not chord midpoints). On the 16→8 jump, ~30% of each ring-k triangle body rises above the ring-(k+1) chord.</p>
    <p><b>Fix: tangent chord (variant F, G).</b> Move ring-(k+1) corners outward so the chord is <em>tangent</em> to r_k<sup>apex</sup> at the midpoint.<br/>
    — Corners on circle R/cos(π/N) · slight radial offset = R·(1/cos(π/N) − 1)<br/>
    — Chord midpoint tangent to R (zero dip)<br/>
    — Ring-(k+1) body entirely at r ≥ R · <em>provably no overlap with ring-k (which is entirely at r ≤ R)</em><br/>
    — Growth factor G(N) = 1 + √3·tan(π/N); side length = 2R·tan(π/N)<br/>
    — Rotation: α_(k+1) = α_k + π/N_k − π/N_(k+1)</p>
    <p><b>Tangent-halving notches (variant F):</b> at each M=2 halving jump, adjacent ring-(k+1) chords meet at a shared corner directly above a skipped ring-k apex. That shared corner is at R/cos(2π/N_k) while the skipped apex sits at R — leaving a radial <em>notch</em> of size R·(1/cos(2π/N_k) − 1):<br/>
    — 128→64: <em>0.12%</em> · invisible<br/>
    — 64→32: <em>0.48%</em> · invisible<br/>
    — 32→16: <em>1.9%</em> · barely visible<br/>
    — 16→8: <em>8.3%</em> · obviously visible (the eight teeth look separated by visible gaps)</p>
    <p><b>Best of both (variant G):</b> tangent chord throughout, halving inside (notches 0.12% / 0.48% / 1.9% — all invisible), then M=1 half-density crown at N=16 instead of halving to N=8. M=1 tangent has <em>zero</em> notches because every ring-k apex tangents a drawn-tooth chord midpoint. Only cost: 2% corner offset at the crown, imperceptible at this scale.</p>
    <p><b>Option β — arc-base fangs</b> (not implemented yet): literally replace the chord with the arc of circle r_k<sup>apex</sup>. Zero overlap, zero notches, perfectly arc-tiled bases. Downside: the shape is a "fang" not a triangle, and Sierpiński subdivision on a fang produces a mix of sub-fangs (along the arc base) and regular triangles (toward the apex) — implementable but breaks the "everything is a standard Sierpiński triangle" invariant. Happy to build this if you want to see it.</p>
    <p><b>Option δ — non-halving integer ratios</b>: M doesn't have to be 2. N=144 can go 144→72→24 (M=2, M=3) for dramatic coarsening. N=120 supports 120→60→20→10→5 for varied five-ring progressions. Tangent-chord math works for any integer M dividing N.</p>
    <p><b>Animation grammar.</b> One keyframe, varying <code>animation-delay</code>. Four independent layers compose.</p>
    <p><b>(1) 2D radial wave (all variants).</b> Every ring's leaves are 2D-bucketized into a local-radial × angular grid (6×4 per ring). Per bucket:<br/>
    — <code>phase = r_global/r_final  +  0.10·(angularIdx/4)  +  0.08·hash(r, a)</code><br/>
    — <code>animation-delay = −phase · 5s</code><br/>
    Radial term dominates (the outward wave). Angular term adds a slight per-sector lag. Hash-noise breaks the ring into organic fingers. All paths run the same <code>@keyframes radiateOut</code>; the delays spread them in time.</p>
    <p><b>(2) Alternating crown (variant H).</b> 16 teeth at N=16 full density, each tooth's opacity phase-flipped by j mod 2. Even peaks at phase 0, odd at phase π. Reads as the 8 bright teeth rotating π/8 each half-cycle.</p>
    <p><b>(3) Per-ring differential rotation (variant I).</b> Each ring sits in a <code>&lt;g class="ring-rotator"&gt;</code> with an inline CSS custom property <code>--end-rot</code> set to 180°/N_k. The group oscillates between 0° and that value via CSS transform. N=128 swings 1.4°, N=16 swings 11.25°. The fractal shears as it breathes — inner rings barely move, outer rings sweep visibly. Combined with (1) the effect is organic, non-synchronized radiation.</p>
    <p><b>(4) F↔G crossfade (variant J).</b> Both F's N=8 halving crown and G's N=16 sparse crown render over the shared inner structure; CSS counter-phase opacity animations (<code>.crossfade-f</code>, <code>.crossfade-g</code>) fade them in and out. Since G midpoints coincide with F midpoints at even ring-4 apexes, the crossfade reads as teeth morphing between wide-tall and narrow-short in place. Opacity-crossfade is the cheap proxy for true vertex interpolation — SVG <code>&lt;animate&gt;</code> can't interpolate paths with different leaf counts, and precomputed same-depth keyframes would be visually muddy.</p>
    <p><b>(5) Per-ring sparse teeth + outward cascade (variant K).</b> Every ring is <em>sparse</em>: drawSlots = even slots of the ring's N-grid (so half the teeth are drawn, gaps at the odd slots). Each ring renders twice — set A at its own alpha, set B at alpha + 2π/N_k (one full triangle angular width, which is exactly the width of one gap). Set B's teeth land cleanly in set A's gaps; together they tile the full N positions without overlap. The sets sit as sibling <code>&lt;g class="set-a"&gt;</code> / <code>&lt;g class="set-b"&gt;</code> with counter-phase opacity animations on the parent <code>&lt;g&gt;</code> (SVG inherits opacity multiplicatively → descendant paths need no animation of their own). Keyframes <code>setPulseA</code> (1→0.05→1) and <code>setPulseB</code> (0.05→1→0.05) ensure A+B≈1.05 at every phase; total ring brightness stays roughly constant but <em>which half</em> of the teeth are bright cycles continuously.</p>
    <p>Per-ring animation-delay is positive and monotone: <code>delay_k = k · period / nRings</code>, with <code>animation-fill-mode: backwards</code> holding outer rings at their first keyframe during their startup. This staggers the A↔B cycle across rings — inner rings' alternation leads, outer rings lag. A wave of "which teeth are bright" ripples outward through every layer. Same grammar at every ring level — inner halving rings AND the crown — because every ring is now sparse in the same way. Shift = triangle width = 2π/N_k; no transform, no geometry interpolation, all opacity.</p>
    <p><b>(6) Granular per-leaf radial wave along the color gradient (variant L).</b> K's set A + set B merged into a single tiled surface — all rings full density, crown upgraded to 16 teeth. Bucketize each ring at <b>16 radial × 8 angular</b> (128 fine buckets/ring, ~640 total across the fractal) and give each bucket an <em>animation-delay proportional to its global radial position</em>: <code>delay_bucket = r_norm · 0.9 · period</code>. The axis of the delay is the axis of the color gradient — so the wave literally sweeps along the burnt-orange-to-pale-yellow spectrum, with inner (burnt) leaves peaking first and outer (pale) leaves peaking last.</p>
    <p>Why positive delays with span 0.9·period (and not negative delays like D/E/F/G)? Negative delays with span ≥ period alias modulo the period — at phase_formula = 1 (outermost), <code>delay = -period</code> is identical to <code>delay = 0</code>, so inner and outer peak simultaneously. This is why D/E/F/G's radial wave never reads as a clean outward sweep; the peak travels middle → (inner AND outer) → middle non-monotonically. Positive delays with span &lt; period avoid aliasing: inner delay 0 → peaks at t = 0.5·period; outer delay 0.9·period → peaks at t = 1.4·period; next inner peak at 1.5·period. A continuous wave with only a 0.1·period gap between "outer peaks" and "next inner peaks" — reads as nearly-continuous outward flow. The cost: a startup lag equal to max delay (0.9·period ≈ 4.5s) during which outer buckets hold their first-keyframe opacity via <code>animation-fill-mode: backwards</code>.</p>
    <p>Granularity: with 128 buckets per ring, each bucket contains a small handful of Sierpiński leaves at similar radial position. Adjacent leaves fade near-simultaneously; the wave appears smooth across thousands of individual sub-triangles. This is the "super granular at the sub-triangle level" interpretation — every tiny leaf participates in the continuous outward flow, phased by its position on the color gradient.</p>
  </div>
</body>

<style>
  :global(html, body) {
    margin: 0;
    background: var(--tome-bg-void);
    color: var(--tome-paper);
    font-family: var(--tome-font-body);
    min-height: 100vh;
  }
  body { padding: 3rem 2rem 6rem; }
  h1 {
    font-family: var(--tome-font-display);
    color: var(--tome-gold);
    text-align: center;
    font-size: 2rem;
    margin: 0 0 0.25rem;
    letter-spacing: 0.04em;
  }
  .sub {
    text-align: center;
    color: var(--tome-term-dim, #8a8565);
    font-family: var(--tome-font-mono);
    font-size: 0.76rem;
    margin: 0 0 3rem;
    letter-spacing: 0.05em;
  }

  /* ─── Hero variant cards ─── */
  .hero {
    max-width: 560px;
    margin: 0 auto 3rem;
    padding: 1.5rem 1.5rem 1.25rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(201, 168, 76, 0.28);
    border-radius: 8px;
    box-shadow: 0 0 40px rgba(201, 168, 76, 0.08);
  }
  .hero-large {
    max-width: 720px;
  }
  .hero h3 {
    font-family: var(--tome-font-heading, var(--tome-font-display));
    margin: 0 0 1rem;
    color: var(--tome-gold);
    font-size: 1.05rem;
    text-align: center;
    letter-spacing: 0.08em;
  }

  .leather-slot {
    background: var(--tome-bg-leather);
    border-radius: 4px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-slot {
    aspect-ratio: 1;
    max-width: 420px;
    margin: 0 auto;
  }
  .hero-slot-large {
    max-width: 600px;
  }

  .photo-wrap {
    position: relative;
    width: 140px;
    height: 140px;
  }
  .photo-wrap img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 45% 32%;
    border-radius: 50%;
    display: block;
    box-shadow: 0 0 0 0.5px rgba(201, 168, 76, 0.35);
    z-index: 3;
  }
  .overlay {
    position: absolute;
    inset: -50px;
    width: calc(100% + 100px);
    height: calc(100% + 100px);
    pointer-events: none;
    overflow: visible;
    z-index: 2;
  }
  .overlay-large {
    inset: -130px;
    width: calc(100% + 260px);
    height: calc(100% + 260px);
  }

  /* ─── Mix K + L (variant M) ───
     Two outward waves (set A at α, set B at α + 2π/N_k) running at
     positive delays with a period/2 offset between them. No quiet gap
     between waves since they fill each other's troughs. */
  .mix-ring path {
    animation: radiateOut 5s linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes radiateOut {
    0%   { opacity: 0.45; }
    50%  { opacity: 1.00; }
    100% { opacity: 0.45; }
  }

  /* ─── Variant N: per-path rise-peak-fade-rest sequential cycle ───
     Every path uses the same radiateOutWave keyframe; per-path
     animation-delay = setOffset + rT · WAVE_SPAN. One set radiates
     outward, holds at peak, then fades from the inside out; the other
     set takes over offset by half a cycle. Ring parity alternates which
     set fires first. */
  .mix-n-ring path {
    animation: radiateOutWave 10s linear infinite;
    animation-fill-mode: backwards;
  }
  /* Rise (0-10%) → peak hold (10-40%, = WAVE_SPAN) → fade (40-50%) →
     rest (50-100%). Peak hold equals WAVE_SPAN so the whole set hits peak
     at one instant (when outer peaks); inner immediately starts fading.
     Fade-end at 50% of cycle = SET_OFFSET, so the next set's inner rises
     exactly when this set's inner finishes fading. */
  @keyframes radiateOutWave {
    0%   { opacity: 0.05; }
    10%  { opacity: 1.00; }
    30%  { opacity: 1.00; }
    50%  { opacity: 0.05; }
    100% { opacity: 0.05; }
  }

  /* ─── N-static override ───
     Same DOM as variant N but every animation cancelled and every
     path forced to full opacity. Use to inspect the four-set tiling
     pattern without temporal motion. */
  .mix-n-ring.static .mix-n-set-a,
  .mix-n-ring.static .mix-n-set-b,
  .mix-n-ring.static .mix-n-set-c,
  .mix-n-ring.static .mix-n-set-d,
  .mix-n-ring.static path {
    animation: none !important;
    opacity: 1 !important;
  }

  /* ─── N-aurora: persistent baseline + single outward wave ───
     All paths sit at opacity 0.3 baseline; a single radial wave
     boosts each path to 1.0 as it sweeps outward. No set alternation. */
  .aurora-ring path {
    animation: auroraWave 8s linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes auroraWave {
    0%, 100% { opacity: 0.3; }
    25%      { opacity: 1.0; }
    50%      { opacity: 0.3; }
  }

  /* ─── N-spokes: N's keyframe reused, angular phase added via delay ───
     Reuses radiateOutWave from variant N. The visual difference comes
     from the delay function (setOffset + rT·WAVE_SPAN + angular term). */
  .spokes-ring path {
    animation: radiateOutWave 10s linear infinite;
    animation-fill-mode: backwards;
  }

  /* ─── N-pulse: heartbeat, sharp brief pulse with long rest ───
     Pulse occupies 20% of cycle (rise 0-5%, fade 5-20%), rest 80%. */
  .pulse-ring path {
    animation: pulseWave 8s linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes pulseWave {
    0%       { opacity: 0.05; }
    5%       { opacity: 1.00; }
    20%      { opacity: 0.05; }
    100%     { opacity: 0.05; }
  }

  /* ─── N-ripple: concentric ring pulse ───
     Each ring shares one delay; whole ring lights up as a unit.
     Baseline 0.25 keeps structure visible between ripples. */
  .ripple-ring path {
    animation: rippleWave 8s linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes rippleWave {
    0%, 100% { opacity: 0.25; }
    15%      { opacity: 1.00; }
    30%      { opacity: 0.25; }
  }

  /* ─── N-overlap: two waves overlapping via cycle/3 offset ───
     Same profile shape as N but shorter cycle (9s) and tighter set
     handoff, so one set is still at peak when the other starts rising. */
  .overlap-ring path {
    animation: overlapWave 9s linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes overlapWave {
    0%       { opacity: 0.05; }
    10%      { opacity: 1.00; }
    30%      { opacity: 1.00; }
    50%      { opacity: 0.05; }
    100%     { opacity: 0.05; }
  }

  /* ─── Spiral family (N-spiral, N-spiral-pair, N-spiral-bands) ───
     Cycle is 6s and ANGULAR_SPAN matches it (one full revolution per
     cycle), so the wrap from angle 2π back to 0 lands on the same
     phase mod cycle — no seam at the angle boundary. Per-triangle
     bucketing means each j-slot has its own discrete angle, so the
     spiral wavefront is delineated by triangle, not by sector grid.
     Sharp 0.5s rise + 4s slow fade + 1.5s rest (≈ 25% rest). */
  .spiral-ring path,
  .spiral-pair-ring path,
  .spiral-bands-ring path {
    animation: spiralWave 6s linear infinite;
    animation-fill-mode: backwards;
  }
  @keyframes spiralWave {
    0%       { opacity: 0.05; }
    8%       { opacity: 1.00; }
    75%      { opacity: 0.05; }
    100%     { opacity: 0.05; }
  }

  .corona {
    position: absolute;
    inset: -40px;
    border-radius: 50%;
    z-index: 1;
    animation: coronaBreathe 6s ease-in-out infinite;
  }
  .corona.tight {
    inset: -12px;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(232, 214, 140, 0.48) 0%,
      rgba(232, 214, 140, 0.40) 18%,
      rgba(232, 214, 140, 0.30) 32%,
      rgba(201, 168, 76, 0.22) 45%,
      rgba(201, 168, 76, 0.14) 58%,
      rgba(201, 168, 76, 0.07) 72%,
      rgba(201, 168, 76, 0.02) 85%,
      transparent 96%
    );
  }
  @keyframes coronaBreathe {
    0%, 100% { opacity: 0.88; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.04); }
  }

  .hero-note {
    text-align: center;
    font-size: 0.72rem;
    color: var(--tome-term-dim, #8a8565);
    margin-top: 1rem;
    line-height: 1.6;
    font-family: var(--tome-font-mono);
  }
  .hero-note em {
    color: var(--tome-gold);
    font-style: normal;
  }

  /* ─── V5 sliders ─── */
  .sliders {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem 1rem;
    margin: 1.25rem auto 0;
    max-width: 600px;
    font-family: var(--tome-font-mono);
    font-size: 0.75rem;
    color: var(--tome-paper);
  }
  @media (max-width: 520px) { .sliders { grid-template-columns: 1fr; } }
  .sliders label {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .slabel {
    color: var(--tome-gold);
    opacity: 0.8;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
