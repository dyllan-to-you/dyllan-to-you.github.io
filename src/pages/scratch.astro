---
import "../styles/guide.css";

/* ═════════════════════════════════════════════════════════════
   Rule-strict Sierpiński sun construction.

   INVARIANT: every ring k+1 triangle's 2 base corners coincide
   exactly with 2 apex positions of ring k. This rule holds for
   every pair of adjacent rings, by construction — no exceptions.

   DERIVATION: for N equilateral triangles pointing outward with
   base on radius r, each base is a chord of length 2r·sin(π/N),
   its midpoint is at radial distance r·cos(π/N) (sagitta), and
   the triangle height is chord·√3/2 = r·√3·sin(π/N). The apex
   sits at radius r·(cos(π/N) + √3·sin(π/N)) = r·F(N).

   RECURRENCE: r^{base}_{k+1} = r^{apex}_k, α_{k+1} = α_k + π/N_k,
   N_{k+1} = N_k / M where M ∈ {1, 2} is the span multiplier.

   M=1 · N constant · each outer corner at a consecutive inner apex.
   M=2 · N halves · each outer corner at every-other inner apex
         (the skipped inner apex pokes into the outer body).

   All triangles are equilateral by construction — verified via
   |apex − corner|² = 4r²sin²(π/N) = base².
   ═════════════════════════════════════════════════════════════ */

function F(N: number): number {
  return Math.cos(Math.PI / N) + Math.sqrt(3) * Math.sin(Math.PI / N);
}

type Ring = {
  N: number;
  alpha: number;
  rBase: number;
  rApex: number;
  side: number;
};

function buildSunRings(r0: number, N1: number, M: 1 | 2, K: number, rMax: number): Ring[] {
  const rings: Ring[] = [];
  let N = N1;
  let rBase = r0;
  let alpha = 0;
  for (let k = 0; k < K; k++) {
    const side = 2 * rBase * Math.sin(Math.PI / N);
    const rApex = rBase * F(N);
    if (rApex > rMax) break;
    rings.push({ N, alpha, rBase, rApex, side });
    alpha += Math.PI / N;
    rBase = rApex;
    const nextN = N / M;
    if (!Number.isInteger(nextN) || nextN < 3) break;
    N = nextN;
  }
  return rings;
}

function triVerts(
  ring: Ring, j: number
): [[number, number], [number, number], [number, number]] {
  const step = (2 * Math.PI) / ring.N;
  const t1 = ring.alpha + j * step;
  const t2 = ring.alpha + (j + 1) * step;
  const ta = ring.alpha + (j + 0.5) * step;
  return [
    [ring.rBase * Math.cos(t1), ring.rBase * Math.sin(t1)],
    [ring.rBase * Math.cos(t2), ring.rBase * Math.sin(t2)],
    [ring.rApex * Math.cos(ta), ring.rApex * Math.sin(ta)],
  ];
}

/* Sierpiński recursion on an arbitrary (equilateral) triangle
   down to a pixel-size threshold. Returns one concatenated d-string. */
function sierpinskiToPixel(
  A: [number, number],
  B: [number, number],
  C: [number, number],
  minSize: number
): string {
  const parts: string[] = [];
  const stack: [[number, number], [number, number], [number, number]][] = [[A, B, C]];
  while (stack.length) {
    const [p, q, r] = stack.pop()!;
    const dx = p[0] - q[0], dy = p[1] - q[1];
    if (dx * dx + dy * dy <= minSize * minSize) {
      parts.push(
        `M ${p[0].toFixed(2)} ${p[1].toFixed(2)} ` +
        `L ${q[0].toFixed(2)} ${q[1].toFixed(2)} ` +
        `L ${r[0].toFixed(2)} ${r[1].toFixed(2)} Z`
      );
      continue;
    }
    const mPQ: [number, number] = [(p[0] + q[0]) / 2, (p[1] + q[1]) / 2];
    const mPR: [number, number] = [(p[0] + r[0]) / 2, (p[1] + r[1]) / 2];
    const mQR: [number, number] = [(q[0] + r[0]) / 2, (q[1] + r[1]) / 2];
    stack.push([p, mPQ, mPR]);
    stack.push([mPQ, q, mQR]);
    stack.push([mPR, mQR, r]);
  }
  return parts.join(" ");
}

const GRADIENT = ["#B7410E", "#CF6C1C", "#E0932C", "#D4AF37", "#F0D96D", "#F5E99F"];
function ringColor(k: number, K: number): string {
  if (K <= 1) return GRADIENT[0];
  const t = k / (K - 1);
  const idx = t * (GRADIENT.length - 1);
  const i = Math.min(Math.floor(idx), GRADIENT.length - 2);
  const f = idx - i;
  const hx = (s: string, n: number) => parseInt(s.slice(1 + n * 2, 3 + n * 2), 16);
  const to2 = (x: number) => Math.round(x).toString(16).padStart(2, "0");
  const r = hx(GRADIENT[i], 0) + f * (hx(GRADIENT[i + 1], 0) - hx(GRADIENT[i], 0));
  const g = hx(GRADIENT[i], 1) + f * (hx(GRADIENT[i + 1], 1) - hx(GRADIENT[i], 1));
  const b = hx(GRADIENT[i], 2) + f * (hx(GRADIENT[i + 1], 2) - hx(GRADIENT[i], 2));
  return `#${to2(r)}${to2(g)}${to2(b)}`;
}

const VARIANTS = [
  { id: "A", title: "A · Constant N = 16, 3 rings",
    N1: 16, M: 1 as const, K: 3,
    desc: "each ring has 16 triangles · M=1 so every outer corner sits on a consecutive inner apex · growth factor F(16) ≈ 1.319 per ring · rings offset π/16 alternating" },
  { id: "B", title: "B · Constant N = 32, 4 rings",
    N1: 32, M: 1 as const, K: 4,
    desc: "32 per ring, finer texture · F(32) ≈ 1.165, 4 rings fit · densest M=1 option" },
  { id: "C", title: "C · Halving 64 → 32 → 16, 3 rings",
    N1: 64, M: 2 as const, K: 3,
    desc: "N halves each ring (M=2) · each outer corner at every-other inner apex · skipped inner apex pokes into outer body (geometric cost of halving) · growth accelerates" },
  { id: "D", title: "D · Halving 128 → 64 → 32 → 16, 4 rings",
    N1: 128, M: 2 as const, K: 4,
    desc: "higher N₁ lets halving fit 4 rings · innermost very fine (128 tiny) · outermost bold (16 rays) · full fractal zoom-in" },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Hatman sun · rule-strict Sierpiński</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;600&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
</head>
<body>
  <h1>Hatman sun · rule-strict Sierpiński</h1>
  <p class="sub">every ring's base corners align with the prior ring's apexes · derived from F(N) = cos(π/N) + √3·sin(π/N)</p>

  {VARIANTS.map((variant) => {
    const rings = buildSunRings(70, variant.N1, variant.M, variant.K, 132);
    return (
      <section class="hero">
        <h3>{variant.title}</h3>
        <div class="leather-slot hero-slot">
          <div class="photo-wrap hero-wrap">
            <div class="corona tight"></div>
            <svg class="overlay" viewBox="-40 -40 240 240" aria-hidden="true">
              <g transform="translate(80 80)">
                {rings.map((ring, k) => {
                  const fill = ringColor(k, rings.length);
                  return (
                    <g>
                      {Array.from({ length: ring.N }).map((_, j) => {
                        const [A, B, C] = triVerts(ring, j);
                        const d = sierpinskiToPixel(A, B, C, 1.5);
                        return (
                          <path d={d} fill={fill} stroke={fill}
                                stroke-width="0.25" stroke-linejoin="miter"
                                opacity="0.95"/>
                        );
                      })}
                    </g>
                  );
                })}
              </g>
            </svg>
            <img src="/hatman.jpg" alt="Hatman"/>
          </div>
        </div>
        <div class="hero-note">
          {variant.desc} · <em>rings built: {rings.length}/{variant.K}</em>
        </div>
      </section>
    );
  })}

  {/* ═════════════════════════════════════════════════════════════
       V · Interactive — same rule, live parameters
       ═════════════════════════════════════════════════════════════ */}
  <section class="hero v5">
    <h3>V · Interactive — rule enforced</h3>
    <div class="leather-slot hero-slot">
      <div class="photo-wrap hero-wrap">
        <div class="corona tight"></div>
        <svg id="v5-svg" class="overlay" viewBox="-40 -40 240 240" aria-hidden="true">
          <g id="v5-root" transform="translate(80 80)"></g>
        </svg>
        <img src="/hatman.jpg" alt="Hatman"/>
      </div>
    </div>
    <div class="sliders">
      <label>
        <span class="slabel">Innermost count N₁</span>
        <select id="s-n1">
          <option value="8">8</option>
          <option value="12">12</option>
          <option value="16">16</option>
          <option value="24" selected>24</option>
          <option value="32">32</option>
          <option value="48">48</option>
          <option value="64">64</option>
          <option value="96">96</option>
          <option value="128">128</option>
          <option value="192">192</option>
          <option value="256">256</option>
        </select>
      </label>
      <label>
        <span class="slabel">Span multiplier M</span>
        <select id="s-m">
          <option value="1" selected>1 · constant N (corners at consecutive inner apexes)</option>
          <option value="2">2 · halving (corners at every-other inner apex)</option>
        </select>
      </label>
      <label>
        <span class="slabel">Rings requested K</span>
        <input type="range" id="s-k" min="1" max="8" step="1" value="4"/>
        <span class="svalue" id="v-k">4</span>
      </label>
      <label>
        <span class="slabel">Min pixel (recursion)</span>
        <input type="range" id="s-min" min="0.5" max="5" step="0.5" value="1.5"/>
        <span class="svalue" id="v-min">1.5</span>
      </label>
    </div>
    <div class="hero-note" id="v5-status">—</div>
  </section>

  <script is:inline>
    (() => {
      const GRADIENT = ["#B7410E", "#CF6C1C", "#E0932C", "#D4AF37", "#F0D96D", "#F5E99F"];
      const R_PHOTO = 70;
      const R_MAX = 132;

      function F(N) {
        return Math.cos(Math.PI / N) + Math.sqrt(3) * Math.sin(Math.PI / N);
      }

      function buildSunRings(r0, N1, M, K, rMax) {
        const rings = [];
        let N = N1, rBase = r0, alpha = 0;
        for (let k = 0; k < K; k++) {
          const rApex = rBase * F(N);
          if (rApex > rMax) break;
          rings.push({ N, alpha, rBase, rApex });
          alpha += Math.PI / N;
          rBase = rApex;
          const nextN = N / M;
          if (!Number.isInteger(nextN) || nextN < 3) break;
          N = nextN;
        }
        return rings;
      }

      function triVerts(ring, j) {
        const step = (2 * Math.PI) / ring.N;
        const t1 = ring.alpha + j * step;
        const t2 = ring.alpha + (j + 1) * step;
        const ta = ring.alpha + (j + 0.5) * step;
        return [
          [ring.rBase * Math.cos(t1), ring.rBase * Math.sin(t1)],
          [ring.rBase * Math.cos(t2), ring.rBase * Math.sin(t2)],
          [ring.rApex * Math.cos(ta), ring.rApex * Math.sin(ta)],
        ];
      }

      function sierpinskiToPixel(A, B, C, minSize) {
        const parts = [];
        const stack = [[A, B, C]];
        while (stack.length) {
          const [p, q, r] = stack.pop();
          const dx = p[0] - q[0], dy = p[1] - q[1];
          if (dx * dx + dy * dy <= minSize * minSize) {
            parts.push(`M ${p[0].toFixed(2)} ${p[1].toFixed(2)} L ${q[0].toFixed(2)} ${q[1].toFixed(2)} L ${r[0].toFixed(2)} ${r[1].toFixed(2)} Z`);
            continue;
          }
          const mPQ = [(p[0]+q[0])/2, (p[1]+q[1])/2];
          const mPR = [(p[0]+r[0])/2, (p[1]+r[1])/2];
          const mQR = [(q[0]+r[0])/2, (q[1]+r[1])/2];
          stack.push([p, mPQ, mPR]);
          stack.push([mPQ, q, mQR]);
          stack.push([mPR, mQR, r]);
        }
        return parts.join(" ");
      }

      function ringColor(k, K) {
        if (K <= 1) return GRADIENT[0];
        const t = k / (K - 1);
        const idx = t * (GRADIENT.length - 1);
        const i = Math.min(Math.floor(idx), GRADIENT.length - 2);
        const f = idx - i;
        const hx = (s, n) => parseInt(s.slice(1 + n * 2, 3 + n * 2), 16);
        const to2 = (x) => Math.round(x).toString(16).padStart(2, "0");
        const r = hx(GRADIENT[i], 0) + f * (hx(GRADIENT[i+1], 0) - hx(GRADIENT[i], 0));
        const g = hx(GRADIENT[i], 1) + f * (hx(GRADIENT[i+1], 1) - hx(GRADIENT[i], 1));
        const b = hx(GRADIENT[i], 2) + f * (hx(GRADIENT[i+1], 2) - hx(GRADIENT[i], 2));
        return `#${to2(r)}${to2(g)}${to2(b)}`;
      }

      function render(rings, minSize) {
        const out = [];
        rings.forEach((ring, k) => {
          const fill = ringColor(k, rings.length);
          for (let j = 0; j < ring.N; j++) {
            const [A, B, C] = triVerts(ring, j);
            const d = sierpinskiToPixel(A, B, C, minSize);
            out.push(`<path d="${d}" fill="${fill}" stroke="${fill}" stroke-width="0.25" stroke-linejoin="miter" opacity="0.95"/>`);
          }
        });
        return out.join("");
      }

      const root = document.getElementById('v5-root');
      const status = document.getElementById('v5-status');
      const read = () => ({
        N1: parseInt(document.getElementById('s-n1').value, 10),
        M:  parseInt(document.getElementById('s-m').value, 10),
        K:  parseInt(document.getElementById('s-k').value, 10),
        minSize: parseFloat(document.getElementById('s-min').value),
      });
      const update = () => {
        const p = read();
        document.getElementById('v-k').textContent = p.K;
        document.getElementById('v-min').textContent = p.minSize.toFixed(1);
        const rings = buildSunRings(R_PHOTO, p.N1, p.M, p.K, R_MAX);
        root.innerHTML = render(rings, p.minSize);
        const ringCounts = rings.map(r => r.N).join(" → ");
        status.innerHTML = `rings built: <em>${rings.length}/${p.K}</em> · counts: <em>${ringCounts || "(none fit)"}</em> · last apex: <em>${rings.length ? rings[rings.length-1].rApex.toFixed(1) : "—"}</em>`;
      };
      ['s-n1','s-m','s-k','s-min'].forEach(id => {
        document.getElementById(id).addEventListener('input', update);
      });
      update();
    })();
  </script>


  <div class="notes-block">
    <p><b>The rule is now an invariant, not a wish.</b></p>
    <p>Every ring's geometry — radii, triangle sizes, offsets — is <em>derived</em> from the single constraint that each next-ring base corner coincides with an apex of the previous ring. There are no free parameters beyond (r₀, N₁, M, K, minSize).</p>
    <p><b>Key formulas:</b><br/>
    — side<sub>k</sub> = 2·r<sub>k</sub><sup>base</sup>·sin(π/N<sub>k</sub>)<br/>
    — r<sub>k</sub><sup>apex</sup> = r<sub>k</sub><sup>base</sup> · (cos(π/N<sub>k</sub>) + √3·sin(π/N<sub>k</sub>)) = r · F(N)<br/>
    — r<sub>k+1</sub><sup>base</sup> = r<sub>k</sub><sup>apex</sup> &nbsp;(next ring's base on previous apex circle)<br/>
    — α<sub>k+1</sub> = α<sub>k</sub> + π/N<sub>k</sub> &nbsp;(half-step offset so corners land on apexes, not chord midpoints)<br/>
    — N<sub>k+1</sub> = N<sub>k</sub> / M &nbsp;(M=1 or M=2)</p>
    <p><b>Growth factors F(N):</b></p>
    <p>F(8) = 1.587 · F(16) = 1.319 · F(24) = 1.212 · F(32) = 1.165 · F(48) = 1.108 · F(64) = 1.080 · F(96) = 1.053 · F(128) = 1.041 · F(256) = 1.020</p>
    <p><b>Budget note:</b> total growth from r=70 to r=132 = 1.886×. For K rings with constant N, you need F(N)<sup>K</sup> ≤ 1.886 → max rings depends on N. Higher N → more rings fit. For halving, growth is F(N<sub>1</sub>)·F(N<sub>1</sub>/2)·F(N<sub>1</sub>/4)·... which accelerates as N shrinks, so only 3–4 halving rings fit even with large N₁.</p>
    <p><b>Why previous variants broke the rule:</b> they specified explicit triangle heights or used touching-bases on chords (not on arcs), so corner positions were off the prior-ring apex circle. The new construction makes apex positions PRIMARY and derives everything else.</p>
  </div>
</body>

<style>
  :global(html, body) {
    margin: 0;
    background: var(--tome-bg-void);
    color: var(--tome-paper);
    font-family: var(--tome-font-body);
    min-height: 100vh;
  }
  body { padding: 3rem 2rem 6rem; }
  h1 {
    font-family: var(--tome-font-display);
    color: var(--tome-gold);
    text-align: center;
    font-size: 2rem;
    margin: 0 0 0.25rem;
    letter-spacing: 0.04em;
  }
  .sub {
    text-align: center;
    color: var(--tome-term-dim, #8a8565);
    font-family: var(--tome-font-mono);
    font-size: 0.76rem;
    margin: 0 0 3rem;
    letter-spacing: 0.05em;
  }

  /* ─── Hero variant cards ─── */
  .hero {
    max-width: 560px;
    margin: 0 auto 3rem;
    padding: 1.5rem 1.5rem 1.25rem;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(201, 168, 76, 0.28);
    border-radius: 8px;
    box-shadow: 0 0 40px rgba(201, 168, 76, 0.08);
  }
  .hero h3 {
    font-family: var(--tome-font-heading, var(--tome-font-display));
    margin: 0 0 1rem;
    color: var(--tome-gold);
    font-size: 1.05rem;
    text-align: center;
    letter-spacing: 0.08em;
  }

  .leather-slot {
    background: var(--tome-bg-leather);
    border-radius: 4px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-slot {
    aspect-ratio: 1;
    max-width: 420px;
    margin: 0 auto;
  }

  .photo-wrap {
    position: relative;
    width: 140px;
    height: 140px;
  }
  .photo-wrap img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 45% 32%;
    border-radius: 50%;
    display: block;
    box-shadow: 0 0 0 0.5px rgba(201, 168, 76, 0.35);
    z-index: 3;
  }
  .overlay {
    position: absolute;
    inset: -50px;
    width: calc(100% + 100px);
    height: calc(100% + 100px);
    pointer-events: none;
    overflow: visible;
    z-index: 2;
  }

  .corona {
    position: absolute;
    inset: -40px;
    border-radius: 50%;
    z-index: 1;
    animation: coronaBreathe 6s ease-in-out infinite;
  }
  .corona.tight {
    inset: -12px;
    background: radial-gradient(
      circle at 50% 50%,
      rgba(232, 214, 140, 0.48) 0%,
      rgba(232, 214, 140, 0.40) 18%,
      rgba(232, 214, 140, 0.30) 32%,
      rgba(201, 168, 76, 0.22) 45%,
      rgba(201, 168, 76, 0.14) 58%,
      rgba(201, 168, 76, 0.07) 72%,
      rgba(201, 168, 76, 0.02) 85%,
      transparent 96%
    );
  }
  @keyframes coronaBreathe {
    0%, 100% { opacity: 0.88; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.04); }
  }

  .hero-note {
    text-align: center;
    font-size: 0.72rem;
    color: var(--tome-term-dim, #8a8565);
    margin-top: 1rem;
    line-height: 1.6;
    font-family: var(--tome-font-mono);
  }
  .hero-note em {
    color: var(--tome-gold);
    font-style: normal;
  }

  /* ─── V5 sliders ─── */
  .sliders {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem 1rem;
    margin: 1.25rem auto 0;
    max-width: 480px;
    font-family: var(--tome-font-mono);
    font-size: 0.75rem;
    color: var(--tome-paper);
  }
  @media (max-width: 520px) { .sliders { grid-template-columns: 1fr; } }
  .sliders label {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .slabel {
    color: var(--tome-gold);
    opacity: 0.8;
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .svalue {
    display: inline-block;
    margin-left: 0.5rem;
    color: var(--tome-gold-bright);
    font-weight: 600;
  }
  .sliders select, .sliders input[type="range"] {
    background: rgba(0,0,0,0.3);
    color: var(--tome-paper);
    border: 1px solid rgba(201, 168, 76, 0.25);
    border-radius: 3px;
    padding: 0.25rem 0.35rem;
    font-family: inherit;
    font-size: 0.78rem;
  }
  .sliders input[type="range"] { padding: 0; }

  /* ─── Notes ─── */
  .notes-block {
    max-width: 820px;
    margin: 3rem auto 0;
    color: var(--tome-term-dim, #8a8565);
    font-family: var(--tome-font-mono);
    font-size: 0.74rem;
    line-height: 1.8;
  }
  .notes-block p { margin: 0.8rem 0; }
  .notes-block b { color: var(--tome-gold); }
  .notes-block code {
    font-family: var(--tome-font-mono);
    color: var(--tome-gold-bright);
    background: rgba(0, 0, 0, 0.3);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
    font-size: 0.85em;
  }
</style>
</html>

