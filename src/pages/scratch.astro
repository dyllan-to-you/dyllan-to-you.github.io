---
import "../styles/guide.css";

/* ═════════════════════════════════════════════════════════════
   Rule-strict Sierpiński sun construction.

   INVARIANT: every ring k+1 triangle's 2 base corners coincide
   exactly with 2 apex positions of ring k. This rule holds for
   every pair of adjacent rings, by construction — no exceptions.

   DERIVATION: for N equilateral triangles pointing outward with
   base on radius r, each base is a chord of length 2r·sin(π/N),
   its midpoint is at radial distance r·cos(π/N) (sagitta), and
   the triangle height is chord·√3/2 = r·√3·sin(π/N). The apex
   sits at radius r·(cos(π/N) + √3·sin(π/N)) = r·F(N).

   RECURRENCE: r^{base}_{k+1} = r^{apex}_k, α_{k+1} = α_k + π/N_k,
   N_{k+1} = N_k / M where M ∈ {1, 2} is the span multiplier.

   M=1 · N constant · each outer corner at a consecutive inner apex.
   M=2 · N halves · each outer corner at every-other inner apex
         (the skipped inner apex pokes into the outer body).

   Per-leaf gradient: every Sierpiński leaf across every ring is
   colored by its own radial distance from origin — the burnt-to-
   pale gradient blends smoothly across ring boundaries rather than
   stepping at them.

   Thin lines: no stroke expansion on fills; tiny stroke-width=0.08
   of matching color just covers anti-aliasing hairlines.

   All triangles are equilateral by construction — verified via
   |apex − corner|² = 4r²sin²(π/N) = base².
   ═════════════════════════════════════════════════════════════ */

/* Tangent-chord growth factor. Base chord tangent to previous ring's
   apex circle at its midpoint; equilateral triangle over that chord
   lands its apex at R·(1 + √3·tan(π/N)). */
function Gt(N: number): number {
  return 1 + Math.sqrt(3) * Math.tan(Math.PI / N);
}

type Ring = {
  N: number;                // total slot count (determines triangle size and angular step)
  alpha: number;            // rotation offset (radians)
  rBase: number;            // radius of base corners (tangent construction: corners at R/cos(π/N) > R)
  rApex: number;            // radius of triangle apex
  side: number;             // triangle side length
  drawSlots?: number[];     // if set, only these j indices are rendered (sparse ring)
  doubleOffset?: boolean;   // if true, render 2-3 sets at α / α+π/N / α+2π/N for K-style alternation
};

/* Tangent-chord construction. Base is a chord TANGENT to the previous
   ring's apex circle at its midpoint — chord lies entirely at r ≥ R,
   so ring-(k+1) body never intrudes on ring-k territory. Corners sit
   on circle R/cos(π/N), slightly outside R. Rotation offset differs
   from chord-on-R by exactly π/N_(k+1):
     α_(k+1) = α_k + π/N_k − π/N_(k+1)
   This makes chord midpoints coincide with ring-k apexes (tangent
   touching) whenever N_(k+1) divides N_k. */
function buildSunRingsTangent(r0: number, N1: number, M: 1 | 2, K: number, rMax: number): Ring[] {
  const rings: Ring[] = [];
  let N = N1;
  let R = r0;            // tangent circle for this ring
  let alpha = 0;
  for (let k = 0; k < K; k++) {
    const rCorner = R / Math.cos(Math.PI / N);
    const rApex = R * Gt(N);
    if (rApex > rMax) break;
    const side = 2 * R * Math.tan(Math.PI / N);
    rings.push({ N, alpha, rBase: rCorner, rApex, side });
    const nextN = N / M;
    if (!Number.isInteger(nextN) || nextN < 3) break;
    R = rApex;
    alpha = alpha + Math.PI / N - Math.PI / nextN;
    N = nextN;
  }
  return rings;
}

/* Variant G: tangent-chord all the way through. 4 halving rings, then
   M=1 half-density crown at N=16 — same crown shape as E but with
   tangent chord. Zero body overlap anywhere, zero halving notches at
   the crown, only a 2% corner offset at N=16 (imperceptible at 260px). */
function buildVariantG(r0: number, rMax: number): Ring[] {
  const rings = buildSunRingsTangent(r0, 128, 2, 4, rMax);
  if (rings.length < 4) return rings;
  const last = rings[rings.length - 1]; // N=16, tangent-chord
  const crownN = last.N;
  const R = last.rApex;                  // crown's tangent circle
  const crownAlpha = last.alpha;         // M=1 tangent: no α shift
  const crownCorner = R / Math.cos(Math.PI / crownN);
  const crownApex = R * Gt(crownN);
  if (crownApex > rMax) return rings;
  rings.push({
    N: crownN,
    alpha: crownAlpha,
    rBase: crownCorner,
    rApex: crownApex,
    side: 2 * R * Math.tan(Math.PI / crownN),
    drawSlots: Array.from({ length: crownN / 2 }, (_, i) => i * 2),
  });
  return rings;
}

/* Variant K: every ring becomes sparse (drawSlots = even slot indices
   of its N-grid) so set A draws 50% of the teeth and set B, shifted
   by 2π/N_k (one full triangle angular width), lands cleanly in the
   odd slots. Each ring's N triangles tile non-overlappingly across
   the two sets; at any moment half the ring's triangles are bright
   (one set) and half are dim, and which half cycles as the crossfade
   runs. Per-ring delay (k·period/nRings) staggers the crossfade so
   the alternation ripples outward through the layers. All ring types
   — halving inner rings AND the M=1 crown — share the same
   grammar. The crown's original drawSlots are preserved (it was
   already sparse); inner rings get drawSlots = [0, 2, ..., N-2]. */
function buildVariantK(r0: number, rMax: number): Ring[] {
  const rings = buildVariantG(r0, rMax); // same geometry as G
  return rings.map(r => {
    if (r.drawSlots) {
      // Already sparse (crown). Just enable doubleOffset.
      return { ...r, doubleOffset: true };
    }
    // Fully-tiled inner ring. Convert to half-density (even slots of
    // the N-grid). Set B's 2π/N shift will fill the complementary
    // odd slots during the crossfade.
    const evens = Array.from({ length: Math.floor(r.N / 2) }, (_, i) => i * 2);
    return { ...r, drawSlots: evens, doubleOffset: true };
  });
}

function triVerts(
  ring: Ring, j: number
): [[number, number], [number, number], [number, number]] {
  const step = (2 * Math.PI) / ring.N;
  const t1 = ring.alpha + j * step;
  const t2 = ring.alpha + (j + 1) * step;
  const ta = ring.alpha + (j + 0.5) * step;
  return [
    [ring.rBase * Math.cos(t1), ring.rBase * Math.sin(t1)],
    [ring.rBase * Math.cos(t2), ring.rBase * Math.sin(t2)],
    [ring.rApex * Math.cos(ta), ring.rApex * Math.sin(ta)],
  ];
}

/* Sierpiński recursion. Each leaf reports its d-string, centroid
   radial distance from origin, and centroid polar angle. */
type Leaf = { d: string; r: number; angle: number };
function sierpinskiLeaves(
  A: [number, number], B: [number, number], C: [number, number], minSize: number
): Leaf[] {
  const out: Leaf[] = [];
  const stack: [[number, number], [number, number], [number, number]][] = [[A, B, C]];
  while (stack.length > 0) {
    const [p, q, r] = stack.pop()!;
    const dx = p[0] - q[0], dy = p[1] - q[1];
    if (dx * dx + dy * dy <= minSize * minSize) {
      const cx = (p[0] + q[0] + r[0]) / 3;
      const cy = (p[1] + q[1] + r[1]) / 3;
      out.push({
        d:
          `M${p[0].toFixed(2)} ${p[1].toFixed(2)}` +
          `L${q[0].toFixed(2)} ${q[1].toFixed(2)}` +
          `L${r[0].toFixed(2)} ${r[1].toFixed(2)}Z`,
        r: Math.sqrt(cx * cx + cy * cy),
        angle: Math.atan2(cy, cx),
      });
      continue;
    }
    const mPQ: [number, number] = [(p[0] + q[0]) / 2, (p[1] + q[1]) / 2];
    const mPR: [number, number] = [(p[0] + r[0]) / 2, (p[1] + r[1]) / 2];
    const mQR: [number, number] = [(q[0] + r[0]) / 2, (q[1] + r[1]) / 2];
    stack.push([p, mPQ, mPR]);
    stack.push([mPQ, q, mQR]);
    stack.push([mPR, mQR, r]);
  }
  return out;
}

const GRADIENT = ["#B7410E", "#CF6C1C", "#E0932C", "#D4AF37", "#F0D96D", "#F5E99F"];
function gradientAt(t: number): string {
  t = Math.max(0, Math.min(1, t));
  const idx = t * (GRADIENT.length - 1);
  const i = Math.min(Math.floor(idx), GRADIENT.length - 2);
  const f = idx - i;
  const hx = (s: string, n: number) => parseInt(s.slice(1 + n * 2, 3 + n * 2), 16);
  const to2 = (x: number) => Math.round(x).toString(16).padStart(2, "0");
  const r = hx(GRADIENT[i], 0) + f * (hx(GRADIENT[i + 1], 0) - hx(GRADIENT[i], 0));
  const g = hx(GRADIENT[i], 1) + f * (hx(GRADIENT[i + 1], 1) - hx(GRADIENT[i], 1));
  const b = hx(GRADIENT[i], 2) + f * (hx(GRADIENT[i + 1], 2) - hx(GRADIENT[i], 2));
  return `#${to2(r)}${to2(g)}${to2(b)}`;
}

/* 2D per-ring bucketizer. Splits each ring's leaves into a
   N_LOCAL_RADIAL × N_ANGULAR grid. Each returned bucket carries its
   radial average (for global phase/color) and angular index (for
   angular phase jitter). Per-ring output lets each ring render in its
   own rotator <g>. */
const N_LOCAL_RADIAL = 6;
const N_ANGULAR = 4;

type Bucket2D = {
  d: string;
  rAvg: number;        // mean global radial position of leaves in this bucket
  angularIdx: number;  // 0..N_ANGULAR-1 (sector bucketing); 0 for per-triangle
  angle?: number;      // continuous angle in [0, 2π), set by per-triangle bucketing only
};

function bucketizeRing2D(
  ring: Ring,
  minSize: number,
  nRadial: number = N_LOCAL_RADIAL,
  nAngular: number = N_ANGULAR,
): Bucket2D[] {
  const ringMin = ring.rBase * Math.cos(Math.PI / ring.N); // chord midpoint (minimum r in this ring)
  const ringMax = ring.rApex;
  const ringRange = Math.max(1e-6, ringMax - ringMin);
  const key = (ri: number, ai: number) => ri * nAngular + ai;
  const data: Record<number, { d: string; rSum: number; count: number; ai: number }> = {};
  const slots = ring.drawSlots ?? Array.from({ length: ring.N }, (_, j) => j);
  for (const j of slots) {
    const [A, B, C] = triVerts(ring, j);
    const leaves = sierpinskiLeaves(A, B, C, minSize);
    for (const lf of leaves) {
      const rLocal = (lf.r - ringMin) / ringRange;
      const ri = Math.max(0, Math.min(nRadial - 1, Math.floor(rLocal * nRadial)));
      const aT = (lf.angle + Math.PI) / (2 * Math.PI); // [0, 1)
      const ai = Math.max(0, Math.min(nAngular - 1, Math.floor(aT * nAngular)));
      const k = key(ri, ai);
      if (!data[k]) data[k] = { d: "", rSum: 0, count: 0, ai };
      data[k].d += lf.d;
      data[k].rSum += lf.r;
      data[k].count++;
    }
  }
  return Object.values(data).map(v => ({
    d: v.d,
    rAvg: v.rSum / v.count,
    angularIdx: v.ai,
  }));
}

/* Per-triangle bucketizer for spiral variants. Each j-slot in each ring
   becomes one Bucket2D with a continuous angle (the triangle's geometric
   center), so the spiral wavefront is delineated by triangle boundaries
   rather than by sector grid. The angle is in [0, 2π) — paired with
   ANGULAR_SPAN equal to an integer multiple of cycle, the wrap from 2π
   back to 0 is seamless because the phase difference is ≡ 0 (mod cycle). */
function bucketizePerTriangle(ring: Ring, minSize: number): Bucket2D[] {
  const out: Bucket2D[] = [];
  const slots = ring.drawSlots ?? Array.from({ length: ring.N }, (_, k) => k);
  const step = (2 * Math.PI) / ring.N;
  for (const j of slots) {
    const [A, B, C] = triVerts(ring, j);
    const leaves = sierpinskiLeaves(A, B, C, minSize);
    if (leaves.length === 0) continue;
    let dAcc = "";
    let rSum = 0;
    for (const lf of leaves) {
      dAcc += lf.d;
      rSum += lf.r;
    }
    let centerAngle = ring.alpha + (j + 0.5) * step;
    centerAngle = ((centerAngle % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
    out.push({
      d: dAcc,
      rAvg: rSum / leaves.length,
      angularIdx: 0,
      angle: centerAngle,
    });
  }
  return out;
}

type Variant = {
  id: string;
  title: string;
  rMax: number;
  build: (r0: number, rMax: number) => Ring[];
  big?: boolean;
  desc: string;
  mixKL?: boolean;          // variant M — two sets with period/2 chase
  mixKLAlt?: boolean;       // variant N — sequential A+C → B+D handoff
  staticOff?: boolean;      // N-static — geometry-only, no animation
  auroraMode?: boolean;     // N-aurora — persistent baseline, single outward wave
  spokesMode?: boolean;     // N-spokes — N handoff + angular phase for rotating spokes
  pulseMode?: boolean;      // N-pulse — heartbeat: sharp outward pulse with long rest
  rippleMode?: boolean;     // N-ripple — concentric ring-by-ring ripple outward
  overlapMode?: boolean;    // N-overlap — two waves with cycle/3 offset for continuous overlap
  spiralMode?: boolean;     // N-spiral — sharp pulse + dominant angular phase, short rest, seamless one-rev spiral
  spiralPairMode?: boolean; // N-spiral-pair — two spirals: A+C then B+D, sequential handoff
  spiralBandsMode?: boolean;// N-spiral-bands — spiral-pair handoff with ring-parity alternation
};

const VARIANTS: Variant[] = [
  { id: "M", title: "M · animated · K's sparse two-set teeth + L's wave, B offset by period/2",
    rMax: 200, big: true, build: buildVariantK, mixKL: true,
    desc: "K's geometry (each ring sparse with set A at even slots and set B at odd slots, non-overlapping interleave) + L's per-leaf radial wave applied separately to each set. Set A's wave runs with delay = rT · 0.9·period. Set B's wave runs with delay = rT · 0.9·period + 0.5·period — a half-cycle behind. Two continuous outward waves chase each other through the interleaved tooth pattern: even-slot teeth peak first at each radial position, odd-slot teeth peak a half-cycle later. The wave never stops (no quiet gap between cycles because A and B fill each other's troughs), and every tooth peaks twice per period — once when its set's wave passes through." },
  { id: "N", title: "N · animated · sequential A+C → B+D handoff, ring-parity alternation",
    rMax: 200, big: true, build: buildVariantK, mixKLAlt: true,
    desc: "K's ring-level alternation expanded to 4 sets in a sequential rise-peak-fade-rest cycle. Set A at α, B at α + π/N_k, C at α + 2π/N_k, D at α + 3π/N_k. A+C tile at integer-step alignment (A even slots, C odd slots); B+D tile the same ring offset by half a triangle (B fills its even slot pairs, D the gaps) — together every angular position is covered. Every path uses one shared 10s keyframe (10% rise, 40% peak hold, 10% fade, 40% rest); per-path animation-delay = setOffset + rT · WAVE_SPAN. Set A+C and set B+D are offset by half the cycle, so as A+C's inner starts to fade, B+D's inner starts to rise — same per radial position. One set radiates outward, holds, then fades from the inside out; the other takes over fluidly during that fade. Ring parity flips which set fires first: even rings (0, 2) start with A+C, odd rings (1, 3) start with B+D. Adjacent rings always show opposite sets at any moment." },
  { id: "N-static", title: "N-static · same geometry as N, all animations off",
    rMax: 200, big: true, build: buildVariantK, mixKLAlt: true, staticOff: true,
    desc: "Identical render path to variant N but every animation disabled. All four sets (A, B, C, D) sit at full opacity simultaneously — A+C tile the integer-step alignment, B+D tile the half-step-shifted alignment. Use this to study the geometric structure without temporal motion: pause and inspect the four-set double-coverage tiling that the rotating pulse cycles through." },
  { id: "N-aurora", title: "N-aurora · persistent baseline sun with single outward wave",
    rMax: 200, big: true, build: buildVariantK, auroraMode: true,
    desc: "All four sets always visible at baseline opacity 0.3 — the sun is perpetually drawn, no paths ever fade to black. A single radial wave (rT · WAVE_SPAN delay, 8s cycle) boosts each path from 0.3 up to 1.0 and back as it sweeps outward. No set alternation, all sets share the same phase, so the full geometry is always present while one bright crest ripples outward through it. Cleanest 'rays radiating outwards' reading — the sun is always there, and you see the pulse flow out." },
  { id: "N-spokes", title: "N-spokes · N's sequential handoff plus angular phase for rotating spokes",
    rMax: 200, big: true, build: buildVariantK, spokesMode: true,
    desc: "Variant N's sequential A+C → B+D handoff with the same rise-peak-fade-rest keyframe, but each path's delay now includes an angular term: delay = setOffset + rT · WAVE_SPAN + (angularIdx / N_ANGULAR) · ANGULAR_SPAN. With 6 angular sectors and ANGULAR_SPAN = 1.5s, the wave spirals outward rather than sweeping uniformly. Reads as sun rays rotating while also radiating — combines outward radiation with a slow angular sweep for a pinwheel feel." },
  { id: "N-pulse", title: "N-pulse · heartbeat — sharp outward pulse with long rest",
    rMax: 200, big: true, build: buildVariantK, pulseMode: true,
    desc: "All four sets share a single phase (no set offset). Each path's keyframe is a brief bright pulse (0-5% rise, 5-20% fade, 20-100% rest): a thin wavefront races outward over WAVE_SPAN, then 80% of the cycle is quiet at baseline 0.05. Cycle = 8s, WAVE_SPAN = 3.2s. Dramatic single-wave radiation with a long dim pause between pulses — like a sun gently breathing, with each breath a sharp outward burst." },
  { id: "N-ripple", title: "N-ripple · concentric ring-by-ring ripple outward",
    rMax: 200, big: true, build: buildVariantK, rippleMode: true,
    desc: "Each ring is treated as a single unit — all buckets in ring k share the same delay = k · RING_OFFSET. Ring 0 lights up as a whole, then ring 1, ring 2, ring 3 in sequence. No per-bucket radial variation within a ring; just discrete concentric pulses rippling outward. Baseline 0.25 keeps the structure visible between pulses. Reads as water-drop ripples expanding from the photo — each ring a discrete crest moving outward." },
  { id: "N-overlap", title: "N-overlap · two waves overlapping — cycle/3 offset instead of cycle/2",
    rMax: 200, big: true, build: buildVariantK, overlapMode: true,
    desc: "Same geometry and handoff structure as N but with SET_OFFSET = cycle/3 instead of cycle/2. The second set starts rising while the first set is still at peak (not yet fading) — the two tilings overlap in brightness for a portion of each cycle. Multiple waves in flight simultaneously; no moment of dimness. Densest continuous-radiation feel — the sun never gets a chance to rest, always something lighting up somewhere." },
  { id: "N-spiral", title: "N-spiral · seamless single spiral, per-triangle delineation",
    rMax: 200, big: true, build: buildVariantK, spiralMode: true,
    desc: "Sharp pulse keyframe (heartbeat) + dominant angular phase, with two critical fixes from earlier iteration: (1) per-triangle bucketing — each j-slot is one path with a continuous center angle, so the wavefront is delineated by triangle boundaries, not by an artificial sector grid; (2) ANGULAR_SPAN equal to cycle (6s = 1 revolution), so adjacent triangles at the angle 2π/0 wrap have phase difference ≡ 0 (mod cycle) — no seam on the left side. WAVE_SPAN = 1.5s. All four sets unison; delay = rT · 1.5 + (angle / 2π) · 6. Reads as a single seamless spiral arm continuously rotating outward." },
  { id: "N-spiral-pair", title: "N-spiral-pair · two spirals: A+C then B+D handoff",
    rMax: 200, big: true, build: buildVariantK, spiralPairMode: true,
    desc: "Two N-spirals chasing each other. Set A+C runs the spiral with phase 0; set B+D runs the same spiral with phase = cycle/2 (3s offset). At every (radial, angular) position, A+C's path fades just as B+D's path rises. Adjacent triangles in the two tilings are offset by half a triangle width geometrically AND half a cycle temporally — the two spirals interlock. Per-triangle delineation, ANGULAR_SPAN = cycle = 6s for seamless wrap, WAVE_SPAN = 1.5s. Reads as two galactic arms spiraling outward in alternation." },
  { id: "N-spiral-bands", title: "N-spiral-bands · spiral-pair handoff with ring-parity alternation",
    rMax: 200, big: true, build: buildVariantK, spiralBandsMode: true,
    desc: "Same as N-spiral-pair but with ring-parity flip on top: even rings (0, 2) fire A+C first then B+D; odd rings (1, 3) fire B+D first then A+C. So at any given moment, ring 0 is showing one spiral phase while ring 1 shows the opposite, ring 2 matches ring 0, ring 3 matches ring 1. Concentric bands of counter-phase spirals, each band radiating outward and rotating angularly. Per-triangle delineation, ANGULAR_SPAN = cycle = 6s seamless." },
];

const MIN_SIZE = 1.0;
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Hatman sun · rule-strict Sierpiński</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;600&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet"/>
</head>
<body>
  <h1>Hatman sun · rule-strict Sierpiński</h1>
  <p class="sub">per-leaf gradient · thin lines · rule enforced: every ring's base corners align with the prior ring's apexes · F(N) = cos(π/N) + √3·sin(π/N)</p>

  {VARIANTS.map((variant) => {
    const rings = variant.build(70, variant.rMax);
    const rFinal = rings.length > 0
      ? Math.max(...rings.map(r => r.rApex))
      : 70;
    const WAVE_PERIOD = 5; // seconds; radial outward pulse duration
    // Large variants use a 400-unit viewBox (±200); standard use 240 (±120 offset from photo center).
    const vb = variant.big ? "-200 -200 400 400" : "-40 -40 240 240";
    const tr = variant.big ? "translate(0 0)" : "translate(80 80)";
    // Summarize ring structure for the status line. All mixKLAlt-family
    // variants (N and its flavours) render 4 sets; M renders 2.
    const is4Set = variant.mixKLAlt || variant.auroraMode || variant.spokesMode ||
                   variant.pulseMode || variant.rippleMode || variant.overlapMode ||
                   variant.spiralMode || variant.spiralPairMode || variant.spiralBandsMode;
    const setCount = is4Set ? 4 : 2;
    const ringSummary = rings
      .map(r => {
        if (r.doubleOffset) return r.drawSlots ? `${r.drawSlots.length}×${setCount}/${r.N}` : `${r.N}×${setCount}`;
        if (r.drawSlots) return `${r.drawSlots.length}/${r.N}`;
        return `${r.N}`;
      })
      .join(" → ");
    return (
      <section class={variant.big ? "hero hero-large" : "hero"}>
        <h3>{variant.title}</h3>
        <div class={variant.big ? "leather-slot hero-slot hero-slot-large" : "leather-slot hero-slot"}>
          <div class="photo-wrap hero-wrap">
            <div class="corona tight"></div>
            <svg class={variant.big ? "overlay overlay-large" : "overlay"} viewBox={vb} aria-hidden="true">
              <g transform={tr} shape-rendering="geometricPrecision">
                {rings.map((ring, ringIdx) => {
                  // All mixKLAlt-family variants share the same 4-set geometry
                  // (A, B, C, D at α + k·π/N) but differ in:
                  //   (1) delay function — what each path's animation-delay is
                  //   (2) ring class — which CSS keyframe governs the animation
                  //   (3) static override — whether animations run at all
                  // The dispatch table below assigns these per variant flag.
                  const isMixKLAltFamily = ring.doubleOffset && (
                    variant.mixKLAlt || variant.auroraMode || variant.spokesMode ||
                    variant.pulseMode || variant.rippleMode || variant.overlapMode ||
                    variant.spiralMode || variant.spiralPairMode || variant.spiralBandsMode
                  );
                  if (isMixKLAltFamily) {
                    const isEven = ringIdx % 2 === 0;
                    const isSpiralFamily = variant.spiralMode || variant.spiralPairMode || variant.spiralBandsMode;
                    // Spiral variants use per-triangle bucketing for clean delineation;
                    // others use the 12 × 6 sector grid.
                    const bucketsA = isSpiralFamily
                      ? bucketizePerTriangle(ring, MIN_SIZE)
                      : bucketizeRing2D(ring, MIN_SIZE, 12, 6);
                    const ringB: Ring = { ...ring, alpha: ring.alpha + Math.PI / ring.N };
                    const bucketsB = isSpiralFamily
                      ? bucketizePerTriangle(ringB, MIN_SIZE)
                      : bucketizeRing2D(ringB, MIN_SIZE, 12, 6);
                    const ringC: Ring = { ...ring, alpha: ring.alpha + (2 * Math.PI) / ring.N };
                    const bucketsC = isSpiralFamily
                      ? bucketizePerTriangle(ringC, MIN_SIZE)
                      : bucketizeRing2D(ringC, MIN_SIZE, 12, 6);
                    const ringD: Ring = { ...ring, alpha: ring.alpha + (3 * Math.PI) / ring.N };
                    const bucketsD = isSpiralFamily
                      ? bucketizePerTriangle(ringD, MIN_SIZE)
                      : bucketizeRing2D(ringD, MIN_SIZE, 12, 6);

                    let ringClass: string;
                    // delayFn now takes the bucket itself so spiral variants can read
                    // bucket.angle (continuous) without falling back to angularIdx.
                    let delayFn: (b: Bucket2D, setRole: "AC" | "BD") => number;

                    if (variant.auroraMode) {
                      ringClass = "aurora-ring";
                      const WAVE_SPAN = 4;
                      delayFn = (b) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        return rT * WAVE_SPAN;
                      };
                    } else if (variant.spokesMode) {
                      ringClass = "spokes-ring";
                      const SET_OFFSET = 5;
                      const WAVE_SPAN = 3;
                      const ANGULAR_SPAN = 1.5;
                      delayFn = (b, setRole) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const setOff = (setRole === "AC") === isEven ? 0 : SET_OFFSET;
                        return setOff + rT * WAVE_SPAN + (b.angularIdx / 6) * ANGULAR_SPAN;
                      };
                    } else if (variant.pulseMode) {
                      ringClass = "pulse-ring";
                      const WAVE_SPAN = 3.2;
                      delayFn = (b) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        return rT * WAVE_SPAN;
                      };
                    } else if (variant.rippleMode) {
                      ringClass = "ripple-ring";
                      const RING_OFFSET = 0.6;
                      const perRingDelay = ringIdx * RING_OFFSET;
                      delayFn = () => perRingDelay;
                    } else if (variant.overlapMode) {
                      ringClass = "overlap-ring";
                      const SET_OFFSET = 3;
                      const WAVE_SPAN = 2.25;
                      delayFn = (b, setRole) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const setOff = (setRole === "AC") === isEven ? 0 : SET_OFFSET;
                        return setOff + rT * WAVE_SPAN;
                      };
                    } else if (variant.spiralMode) {
                      // Single seamless spiral, all sets unison, per-triangle delineation.
                      ringClass = "spiral-ring";
                      const WAVE_SPAN = 1.5;
                      const ANGULAR_SPAN = 6;  // = cycle (1 revolution, seamless wrap)
                      delayFn = (b) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const angle = b.angle ?? 0;
                        return rT * WAVE_SPAN + (angle / (2 * Math.PI)) * ANGULAR_SPAN;
                      };
                    } else if (variant.spiralPairMode) {
                      // Two spirals chasing each other: A+C at offset 0, B+D at cycle/2.
                      ringClass = "spiral-pair-ring";
                      const SET_OFFSET = 3;     // = cycle/2
                      const WAVE_SPAN = 1.5;
                      const ANGULAR_SPAN = 6;   // = cycle (seamless)
                      delayFn = (b, setRole) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const angle = b.angle ?? 0;
                        const setOff = setRole === "AC" ? 0 : SET_OFFSET;
                        return setOff + rT * WAVE_SPAN + (angle / (2 * Math.PI)) * ANGULAR_SPAN;
                      };
                    } else if (variant.spiralBandsMode) {
                      // Spiral-pair handoff plus ring-parity flip on which set fires first.
                      ringClass = "spiral-bands-ring";
                      const SET_OFFSET = 3;
                      const WAVE_SPAN = 1.5;
                      const ANGULAR_SPAN = 6;
                      delayFn = (b, setRole) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const angle = b.angle ?? 0;
                        const setOff = (setRole === "AC") === isEven ? 0 : SET_OFFSET;
                        return setOff + rT * WAVE_SPAN + (angle / (2 * Math.PI)) * ANGULAR_SPAN;
                      };
                    } else {
                      // Variant N (mixKLAlt) — sequential handoff with ring parity flip.
                      ringClass = variant.staticOff ? "mix-n-ring static" : "mix-n-ring";
                      const SET_OFFSET = 5;
                      const WAVE_SPAN = 3;
                      delayFn = (b, setRole) => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const setOff = (setRole === "AC") === isEven ? 0 : SET_OFFSET;
                        return setOff + rT * WAVE_SPAN;
                      };
                    }

                    const renderSet = (buckets: Bucket2D[], setRole: "AC" | "BD") =>
                      buckets.map(b => {
                        const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                        const color = gradientAt(rT);
                        const delay = delayFn(b, setRole);
                        return (
                          <path d={b.d} fill={color} stroke={color}
                                stroke-width="0.08" stroke-linejoin="miter"
                                style={`animation-delay: ${delay.toFixed(3)}s`}/>
                        );
                      });
                    return (
                      <g class={ringClass}>
                        <g class="mix-n-set-a">{renderSet(bucketsA, "AC")}</g>
                        <g class="mix-n-set-b">{renderSet(bucketsB, "BD")}</g>
                        <g class="mix-n-set-c">{renderSet(bucketsC, "AC")}</g>
                        <g class="mix-n-set-d">{renderSet(bucketsD, "BD")}</g>
                      </g>
                    );
                  }
                  // Variant M (mixKL): K's two-set geometry (A at α, B at α + 2π/N_k
                  // = full width → odd slots of A's grid; non-overlapping interleave)
                  // + L's per-leaf wave per set, with B offset by period/2 so the two
                  // outward waves chase each other through interleaved tooth slots.
                  if (ring.doubleOffset && variant.mixKL) {
                    const bucketsA = bucketizeRing2D(ring, MIN_SIZE, 16, 8);
                    const ringB: Ring = { ...ring, alpha: ring.alpha + 2 * Math.PI / ring.N };
                    const bucketsB = bucketizeRing2D(ringB, MIN_SIZE, 16, 8);
                    const MIX_SPAN = WAVE_PERIOD * 0.9;
                    const SET_B_OFFSET = WAVE_PERIOD * 0.5;
                    return (
                      <g class="mix-ring">
                        {bucketsA.map(b => {
                          const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                          const color = gradientAt(rT);
                          const delay = rT * MIX_SPAN;
                          return (
                            <path d={b.d} fill={color} stroke={color}
                                  stroke-width="0.08" stroke-linejoin="miter"
                                  style={`animation-delay: ${delay.toFixed(3)}s`}/>
                          );
                        })}
                        {bucketsB.map(b => {
                          const rT = (b.rAvg - 70) / Math.max(1e-6, rFinal - 70);
                          const color = gradientAt(rT);
                          const delay = rT * MIX_SPAN + SET_B_OFFSET;
                          return (
                            <path d={b.d} fill={color} stroke={color}
                                  stroke-width="0.08" stroke-linejoin="miter"
                                  style={`animation-delay: ${delay.toFixed(3)}s`}/>
                          );
                        })}
                      </g>
                    );
                  }
                  // No other variants render rings; reaching here means the variant
                  // config was malformed. Return null so React/Astro skips the slot.
                  return null;
                })}
              </g>
            </svg>
            <img src="/hatman.jpg" alt="Hatman"/>
          </div>
        </div>
        <div class="hero-note">
          {variant.desc} · <em>rings: {ringSummary}</em> · <em>r_final ≈ {rFinal.toFixed(1)}</em>
        </div>
      </section>
    );
  })}

  {/* ═════════════════════════════════════════════════════════════
       V · Interactive — same rule, live parameters
       (large overlay; R_MAX is a slider so you can explore K ≥ 5)
       ═════════════════════════════════════════════════════════════ */}
  <section class="hero hero-large v5">
    <h3>V · Interactive — rule enforced · per-leaf gradient</h3>
    <div class="leather-slot hero-slot hero-slot-large">
      <div class="photo-wrap hero-wrap">
