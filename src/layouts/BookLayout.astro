---
import { getCollection } from "astro:content";
import Tome from "../components/tome/Tome.svelte";
import StickyNote from "../components/post/StickyNote.svelte";
import { extractSections } from "../lib/page";
import { renderBody as renderWritingBody, getReadingTime, type Writing } from "../lib/writing";
import "../styles/guide.css";

interface Props {
  title?: string;
}

const { title = "Justice — Builder · Musician · Architect" } = Astro.props;

// Book pages — sorted by declared order.
const rawPages = await getCollection("pages");
const sortedPages = rawPages.sort((a, b) => a.data.order - b.data.order);

// Writings — newest first for card listing; same order for in-book pages.
const publishedWritings = (
  await getCollection("writings", ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

/** Format a writing's date for the in-book header. */
function fmtDate(d: Date): string {
  return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

/** Render a writing as the HTML body of an in-book page. Includes title,
 *  description, date/tags, and the voice-attributed body. Styles are shared
 *  globally below via .writing-header / .writing-body overrides. */
function renderWritingAsBookPage(w: Writing): string {
  const tags = w.tags.map((t) => `<span class="tag">#${escapeHtml(t)}</span>`).join(" ");
  const subtitle = w.description ? `<p class="writing-subtitle">${escapeHtml(w.description)}</p>` : "";
  const tagsMarkup = tags ? `<span class="tags">${tags}</span>` : "";
  const readingMinutes = getReadingTime(w);
  return `
<header class="writing-header">
  <h1 class="writing-title">${escapeHtml(w.title)}</h1>
  ${subtitle}
  <div class="writing-meta">
    <time datetime="${w.date.toISOString()}">${fmtDate(w.date)}</time>
    <span class="reading-time">${readingMinutes} min read</span>
    ${tagsMarkup}
  </div>
</header>
<div class="writing-body">
${renderWritingBody(w)}
</div>
`.trim();
}

// Compose the tome page array. Writings are injected right after the
// "writings" index page so they live as interior chapters of the book.
type TomePage = {
  slug: string;
  order: number;
  label: string;
  toc?: string;
  pageLayout: "cover" | "content";
  variant?: "front" | "back";
  chapter?: { number: string; title: string; subtitle?: string };
  backFace?: "cover";
  body?: string;
  sections?: { id: string; text: string }[];
  prompt?: string;
  quote?: string;
  attribution?: string;
  lines?: { text: string; italic?: boolean; mono?: boolean }[];
  cards?: { name: string; description: string; href?: string }[];
  cardsSource?: "writings";
  header?: string;
  closing?: string;
};

const pages: TomePage[] = [];

for (const entry of sortedPages) {
  const data = entry.data;
  let cards = data.cards;
  if (data.cardsSource === "writings") {
    // Cards on the writings index page link to the in-book pages that
    // follow. Hrefs stay as permalinks for shareability; the tome engine
    // flips in-book when the slug matches a known page.
    cards = publishedWritings.map((w) => ({
      name: w.data.title,
      description: w.data.description ?? "",
      href: `/writings/${w.id}`,
    }));
  }

  pages.push({
    ...data,
    body: data.body,
    sections: data.body ? extractSections(data.body) : [],
    cards,
  });

  // Inject writings as book pages after the Writings index.
  if (data.slug === "writings") {
    for (const w of publishedWritings) {
      pages.push({
        slug: `writings/${w.id}`,
        order: 0,
        label: w.data.title,
        toc: w.data.title,
        pageLayout: "content",
        header: `> writings / ${w.id}`,
        body: renderWritingAsBookPage(w.data),
      });
    }
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Personal site of Dyllan Justice Tô-Yu — solo founder of Playfaire PBC." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Tome client:load pages={pages} />
    <StickyNote client:load />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    overflow: hidden;
  }

  /* ─── In-book writing styling ─────────────────────────────────────── */
  .writing-header {
    margin: 4px 0 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(184, 115, 51, 0.18);
  }
  .writing-title {
    font-family: var(--tome-font-display);
    color: var(--tome-ink);
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 6px;
    letter-spacing: 0.01em;
  }
  .writing-subtitle {
    font-family: var(--tome-font-body);
    font-style: italic;
    color: var(--tome-ink-light);
    font-size: 0.85rem;
    line-height: 1.4;
    margin: 0 0 10px;
  }
  .writing-meta {
    font-family: var(--tome-font-mono);
    color: var(--tome-term-dim);
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .writing-meta .tags { display: inline-flex; gap: 6px; }
  .writing-meta .tag { color: var(--tome-term-green); opacity: 0.75; }

  .writing-body {
    font-family: var(--tome-font-body);
    color: var(--tome-ink);
    font-size: 0.92rem;
    line-height: 1.7;
  }
  .writing-body p { margin: 0 0 14px; }
  .writing-body p:last-child { margin: 0; }
  .writing-body hr {
    width: 60px; height: 1px; border: none; margin: 18px auto;
    background: linear-gradient(90deg, transparent, var(--tome-copper), transparent);
  }
  .writing-body a {
    color: var(--tome-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .writing-body a:hover { color: var(--tome-voice-justice); }

  .voice-legend {
    font-family: var(--tome-font-mono);
    font-size: 0.7rem;
    line-height: 1.5;
    color: var(--tome-term-dim);
    padding: 10px 12px;
    margin: 0 0 14px;
    border: 1px solid rgba(184, 115, 51, 0.18);
    border-radius: 2px;
    background: rgba(224, 208, 176, 0.25);
  }
</style>
