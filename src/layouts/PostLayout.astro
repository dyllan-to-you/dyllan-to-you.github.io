---
import "../styles/guide.css";
import StickyNote from "../components/post/StickyNote.svelte";

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;

const dateStr = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const isoDate = date.toISOString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Justice</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={isoDate} />
    <link rel="alternate" type="application/rss+xml" title="Justice — Writings" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="post-root">
      <article class="parchment" aria-labelledby="post-title">
        <a class="back-dogear" href="/writings" aria-label="Back to writings">
          <span class="dogear-arrow">←</span>
          <span class="dogear-label">writings</span>
        </a>

        <div class="scroll-area">
          <header class="post-header">
            <div class="eyebrow">&gt; writings / post</div>
            <h1 id="post-title">{title}</h1>
            {description && <p class="subtitle">{description}</p>}
            <div class="meta">
              <time datetime={isoDate}>{dateStr}</time>
              {tags.length > 0 && (
                <span class="tags">
                  {tags.map((t) => <span class="tag">#{t}</span>)}
                </span>
              )}
            </div>
          </header>

          <div class="body">
            <slot />
          </div>

          <footer class="post-footer">
            <div class="rule"></div>
            <a class="return-link" href="/writings">&lt; return to writings</a>
          </footer>
        </div>
      </article>
      <StickyNote client:load />
    </div>

    <style is:global>
      body {
        margin: 0;
        background: var(--tome-bg-void);
        font-family: var(--tome-font-body);
        color: var(--tome-ink);
        min-height: 100vh;
      }

      .post-root {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5vh 2.5vw;
        box-sizing: border-box;
      }

      .parchment {
        position: relative;
        width: 100%;
        max-width: 720px;
        height: 95vh;
        background: var(--tome-bg-paper);
        border-radius: 3px;
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(160, 120, 60, 0.2);
        display: flex;
        flex-direction: column;
      }

      .scroll-area {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        padding: 72px 56px 48px;
        mask-image: linear-gradient(to bottom, black calc(100% - 32px), transparent);
        -webkit-mask-image: linear-gradient(to bottom, black calc(100% - 32px), transparent);
      }
      .scroll-area::-webkit-scrollbar { width: 4px; }
      .scroll-area::-webkit-scrollbar-track { background: transparent; }
      .scroll-area::-webkit-scrollbar-thumb {
        background: rgba(160, 120, 60, 0.3);
        border-radius: 2px;
      }
      .scroll-area { scrollbar-width: thin; scrollbar-color: rgba(160, 120, 60, 0.3) transparent; }

      .back-dogear {
        position: absolute;
        top: 0; left: 0;
        z-index: 2;
        padding: 10px 14px;
        font-family: var(--tome-font-mono);
        color: var(--tome-term-green);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-decoration: none;
        background: linear-gradient(135deg, rgba(224, 208, 176, 0.85) 50%, transparent 50%);
        border-bottom-right-radius: 8px;
        display: flex;
        gap: 6px;
        align-items: center;
        opacity: 0.75;
        transition: opacity 0.18s ease, background 0.18s ease;
      }
      .back-dogear:hover,
      .back-dogear:focus-visible {
        opacity: 1;
        outline: none;
      }
      .dogear-arrow { font-size: 0.9rem; }

      .post-header {
        margin-bottom: 32px;
      }
      .eyebrow {
        font-family: var(--tome-font-mono);
        color: var(--tome-term-dim);
        font-size: 0.6rem;
        letter-spacing: 0.12em;
        margin-bottom: 14px;
        opacity: 0.7;
      }
      .post-header h1 {
        font-family: var(--tome-font-display);
        color: var(--tome-ink);
        font-size: 1.9rem;
        font-weight: 500;
        line-height: 1.2;
        margin: 0 0 8px;
        letter-spacing: 0.01em;
      }
      .subtitle {
        font-family: var(--tome-font-body);
        font-style: italic;
        color: var(--tome-ink-light);
        font-size: 1.1rem;
        line-height: 1.45;
        margin: 0 0 16px;
      }
      .meta {
        font-family: var(--tome-font-mono);
        color: var(--tome-term-dim);
        font-size: 0.65rem;
        letter-spacing: 0.06em;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        align-items: center;
      }
      .tags { display: inline-flex; gap: 8px; }
      .tag {
        color: var(--tome-term-green);
        opacity: 0.75;
      }

      .body {
        font-family: var(--tome-font-body);
        color: var(--tome-ink);
        font-size: 1.0625rem;
        line-height: 1.75;
      }
      .body h2 {
        font-family: var(--tome-font-mono);
        color: var(--tome-term-green);
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        margin: 32px 0 8px;
        font-weight: normal;
      }
      .body h2::before { content: "> "; }
      .body h3 {
        font-family: var(--tome-font-heading);
        color: var(--tome-ink);
        font-size: 1.1rem;
        font-weight: 500;
        margin: 24px 0 8px;
      }
      .body p { margin: 0 0 16px; }
      .body p:last-child { margin: 0; }
      .body a {
        color: var(--tome-link);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }
      .body a:hover { color: var(--tome-voice-justice); }
      .body hr {
        width: 80px; height: 1px; border: none; margin: 24px auto;
        background: linear-gradient(90deg, transparent, var(--tome-copper), transparent);
      }
      .body blockquote {
        border-left: 2px solid rgba(184, 115, 51, 0.4);
        padding-left: 16px;
        margin: 16px 0;
        color: var(--tome-ink-light);
        font-style: italic;
      }
      .body code {
        font-family: var(--tome-font-mono);
        background: rgba(45, 107, 63, 0.08);
        padding: 1px 6px;
        border-radius: 2px;
        font-size: 0.85em;
      }
      .body pre {
        background: rgba(42, 26, 10, 0.05);
        border: 1px solid rgba(184, 115, 51, 0.2);
        border-radius: 3px;
        padding: 14px 16px;
        overflow-x: auto;
        font-size: 0.82rem;
        line-height: 1.55;
      }
      .body pre code {
        background: none;
        padding: 0;
      }
      .body ul, .body ol {
        margin: 0 0 16px;
        padding-left: 24px;
      }
      .body li { margin-bottom: 6px; }

      .post-footer {
        margin-top: 48px;
        text-align: center;
      }
      .rule {
        width: 60px; height: 1px; margin: 0 auto 20px;
        background: linear-gradient(90deg, transparent, var(--tome-copper), transparent);
      }
      .return-link {
        font-family: var(--tome-font-mono);
        color: var(--tome-term-dim);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.18s ease, color 0.18s ease;
      }
      .return-link:hover,
      .return-link:focus-visible {
        color: var(--tome-term-green);
        opacity: 1;
        outline: none;
      }

      @media (max-width: 640px) {
        .post-root { padding: 1vh 2vw; }
        .parchment { height: 98vh; }
        .scroll-area { padding: 56px 24px 32px; }
        .post-header h1 { font-size: 1.5rem; }
      }
    </style>
  </body>
</html>
